@prefix sh:     <http://www.w3.org/ns/shacl#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <http://schema.org/> .
@prefix niod:   <https://data.niod.nl/> .
@prefix dct:    <http://purl.org/dc/terms/> .
@prefix picom:  <https://personsincontext.org/model#> .

### 1. SHAPE VOOR OBJECTEN (CreativeWork en subclasses)
# Dit geldt voor Boek, Foto, Archiefmateriaal, etc.
niod:CreativeWorkShape
    a sh:NodeShape ;
    sh:targetClass schema:CreativeWork, niod:Afbeelding, niod:Archiefmateriaal, niod:Monument, niod:Certificate ;
    sh:name "Object"@nl ;
    sh:description "Basisregels voor alle collectiestukken en documenten."@nl ;

    # Voorbeeld property uit Dublin Core
    sh:property [
        sh:path dct:title ;
        sh:name "Titel"@nl ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
    ] ;

    # NIOD specifieke property voor IIIF
    sh:property [
        sh:path niod:imageIIIF ;
        sh:name "IIIF Manifest"@nl ;
        sh:description "Link naar het IIIF manifest van het object."@nl ;
        sh:nodeKind sh:IRI ;
    ] .

### 2. SHAPE VOOR GEBEURTENISSEN (Event en alle subclasses zoals Omgekomen, Gevangen, etc.)
niod:EventShape
    a sh:NodeShape ;
    sh:targetClass schema:Event, niod:Omgekomen, niod:Gevangen, niod:Gearresteerd, niod:Bekendmaking ;
    sh:name "Gebeurtenis"@nl ;

    # NIOD Property: Slachtoffer
    sh:property [
        sh:path niod:slachtoffer ;
        sh:name "Slachtoffer"@nl ;
        sh:description "Persoon die slachtoffer was in deze gebeurtenis."@nl ;
        sh:nodeKind sh:IRI ; # Verwijst naar een schema:Person of picom:PersonObservation
    ] ;

    # NIOD Property: Opdrachtgever (specifiek genoemd voor Bekendmakingen)
    sh:property [
        sh:path niod:opdrachtgever ;
        sh:name "Opdrachtgever"@nl ;
        sh:description "Persoon of organisatie die de opdracht gaf voor de bekendmaking."@nl ;
        sh:nodeKind sh:IRI ;
    ] .

### 3. SHAPE VOOR PERSONEN (Persons In Context)
niod:PersonObservationShape
    a sh:NodeShape ;
    sh:targetClass picom:PersonObservation ;
    sh:name "Persoonsvermelding"@nl ;
    
    sh:property [
        sh:path schema:name ;
        sh:name "Naam"@nl ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
    ] .

### 4. SHAPE VOOR RECHTEN
niod:RightsShape
    a sh:NodeShape ;
    sh:targetClass niod:Rights ;
    sh:name "Rechten"@nl ;
    sh:property [
        sh:path rdfs:label ;
        sh:name "Rechtenverklaring"@nl ;
        sh:datatype xsd:string ;
    ] .
