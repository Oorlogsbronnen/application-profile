schema1:Article rdfs:label "Krantartikel"@nl .

schema1:AudioObject rdfs:label "Audio"@nl .

schema1:Book rdfs:label "Boek"@nl .

schema1:Newspaper rdfs:label "Krant"@nl .

schema1:Painting rdfs:label "Schilderij"@nl .

schema1:Photograph rdfs:label "Foto"@nl ;
    rdfs:subClassOf niod:Afbeelding .

schema1:Sculpture rdfs:label "Beeldhouwwerk"@nl .

schema1:SheetMusic rdfs:label "Bladmuziek"@nl ;
    rdfs:subClassOf niod:Afbeelding .

schema1:VideoObject rdfs:label "Video"@nl .

schema1:VisualArtwork rdfs:label "Kunstwerk"@nl ;
    rdfs:subClassOf niod:Afbeelding .

skos:Concept rdfs:subClassOf :Webpagina .

:CreativeWorkShape a sh:NodeShape ;
    sh:description "Verschillende typen bronnen en objecten die binnen de collectie worden beschreven, zoals artikelen, foto's en kunstwerken."@nl ;
    sh:name "Bronnen en Objecten"@nl ;
    sh:property [ sh:name "Identifier (DC)"@nl ;
            sh:node :Rule_identifier_dc ;
            sh:path dc:identifier ],
        [ sh:name "Titel"@nl ;
            sh:node :Rule_title ;
            sh:path dc:title ],
        [ sh:name "Type (RDF)"@nl ;
            sh:node :Rule_type ;
            sh:path rdf:type ],
        [ sh:name "Type (DC)"@nl ;
            sh:node :Rule_type_dc ;
            sh:path dc:type ],
        [ sh:name "Beschrijving"@nl ;
            sh:node :Rule_description_dc ;
            sh:path dc:description ],
        [ sh:name "Onderwerp"@nl ;
            sh:node :Rule_subject ;
            sh:path dc:subject ],
        [ sh:name "Betreft entiteit"@nl ;
            sh:node :Rule_about ;
            sh:path schema1:about ],
        [ sh:name "Periodisering"@nl ;
            sh:node :Rule_temporal ;
            sh:path schema1:temporal ],
        [ sh:name "Inhoudelijke locatie"@nl ;
            sh:node :Rule_contentLocation ;
            sh:path schema1:contentLocation ],
        [ sh:name "Maker"@nl ;
            sh:node :Rule_creator ;
            sh:path dc:creator ],
        [ sh:name "Uitgever"@nl ;
            sh:node :Rule_publisher ;
            sh:path dc:publisher ],
        [ sh:description "De instelling die het object digitaal beschikbaar stelt."@nl ;
            sh:name "Provider"@nl ;
            sh:node :Rule_provider ;
            sh:path schema1:provider ],
        [ sh:name "Bron"@nl ;
            sh:node :Rule_source ;
            sh:path dc:source ],
        [ sh:description "De verzameling waar dit object deel van uitmaakt."@nl ;
            sh:name "Collectie"@nl ;
            sh:node :Rule_collection ;
            sh:path dcmit:Collection ],
        [ sh:name "Datum"@nl ;
            sh:node :Rule_date ;
            sh:path dc:date ],
        [ sh:name "Startdatum"@nl ;
            sh:node :Rule_startDate ;
            sh:path schema1:startDate ],
        [ sh:name "Einddatum"@nl ;
            sh:node :Rule_endDate ;
            sh:path schema1:endDate ],
        [ sh:name "Thumbnail"@nl ;
            sh:node :Rule_thumbnail ;
            sh:path schema1:thumbnail ] ;
    sh:targetClass niod1:Monument,
        schema1:Article,
        schema1:Book,
        schema1:CreativeWork,
        schema1:Newspaper,
        schema1:Painting,
        schema1:Photograph,
        schema1:Sculpture,
        schema1:SheetMusic,
        schema1:VisualArtwork .

:Rule_endDate sh:maxCount 1 ;
    sh:node :Base_DateOrInteger ;
    sh:path schema1:endDate .

:Rule_hadPrimarySource sh:node :Base_IRI ;
    sh:or ( [ sh:class prov:Entity ] [ sh:class schema1:ArchiveComponent ] ) ;
    sh:path prov:hadPrimarySource .

:Rule_hasOccupation sh:node :Base_String ;
    sh:path schema1:hasOccupation .

:Rule_identifier_schema sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:node :Base_String ;
    sh:path schema1:identifier .

:Rule_name sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:node :Base_String ;
    sh:path schema1:name .

:Rule_provider sh:node :Base_StringOrIRI ;
    sh:path schema1:provider .

:Rule_startDate sh:maxCount 1 ;
    sh:node :Base_DateOrInteger ;
    sh:path schema1:startDate .

:Rule_url sh:node :Base_StringOrIRI ;
    sh:path schema1:url .

:Base_DateOrInteger a sh:PropertyShape ;
    sh:or ( [ sh:datatype xsd:date ] [ sh:datatype xsd:integer ] ) .

:Base_Date a sh:PropertyShape ;
    sh:datatype xsd:date .

:Rule_type sh:node :Base_IRI ;
    sh:path rdf:type .

schema1:CreativeWork rdfs:label "Object"@nl .

:Base_IRI a sh:PropertyShape ;
    sh:nodeKind sh:IRI .

:Base_StringOrIRI a sh:PropertyShape ;
    sh:or ( [ sh:datatype xsd:string ] [ sh:nodeKind sh:IRI ] ) .

:Base_String a sh:PropertyShape ;
    sh:datatype xsd:string .

