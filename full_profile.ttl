:Rule_deathPlace sh:maxCount 1 ;
    sh:node :Base_StringOrIRI ;
    sh:path schema1:deathPlace .

:Rule_deceased sh:maxCount 1 ;
    sh:node :Base_String ;
    sh:path picom1:deceased .

:Rule_description_dc sh:node :Base_String ;
    sh:path dc:description .

:Rule_description_schema sh:node :Base_String ;
    sh:path schema1:description .

:Rule_familyName sh:node :Base_String ;
    sh:path schema1:familyName .

:Rule_fromLocation sh:node :Base_StringOrIRI ;
    sh:path schema1:fromLocation .

:Rule_gender sh:node :Base_StringOrIRI ;
    sh:path schema1:gender .

:Rule_givenName sh:node :Base_String ;
    sh:path schema1:givenName .

:Rule_identifier_dc sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:node :Base_String ;
    sh:path dc:identifier .

:Rule_inDataset sh:class schema1:Dataset ;
    sh:node :Base_IRI ;
    sh:path niod1:inDataset .

:Rule_initials sh:node :Base_String ;
    sh:path pnv:initials .

