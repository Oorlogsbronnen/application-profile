    rdfs:isDefinedBy <https://data.niod.nl/WO2_Thesaurus/events/6355> ;
    rdfs:subClassOf schema1:Event .

niod:Gerecruteerd a rdfs:Class ;
    rdfs:label "Gerecruteerd"@nl ;
