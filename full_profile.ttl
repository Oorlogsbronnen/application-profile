## Classes and properties for 'Bekendmakingen'

niod:Bekendmaking a rdfs:Class ;
 	rdfs:label "Bekendmaking"@nl ;
	rdfs:subClassOf schema:Event ;
	rdf:comment "Class for official announcements, treated as events "@en .

niod:slachtoffer a rdf:Property ;
	rdfs:label "slachtoffer"@nl ;
	rdfs:subPropertyOf schema:actor ;
	rdf:comment "Een persoon die slachtoffer was in een gebeurtenis"@nl .

niod:opdrachtgever a rdf:Property ;
	rdfs:label "opdrachtgever"@nl ;
	rdfs:subPropertyOf schema:actor ;
	rdf:comment "Een persoon die de opdrachtgever was van een bekendmaking"@nl .

niod:genoemde a rdf:Property ;
	rdfs:label "genoemde"@nl ;
	rdfs:subPropertyOf schema:actor ;
	rdf:comment "Een persoon die genoemd wordt bij een bekendmaking"@nl .

## Other NIOD properties

niod:imageIIIF a rdf:Property ;
	rdfs:label "IIIF Manifest"@nl ;
	rdfs:subPropertyOf schema:image ;
	rdf:comment "IIIF manifest van afbeeldingen die bij de bron beschikbaar zijn in IIIF formaat"@nl .

## Class for rights statements

niod:Rights a rdfs:Class ;
	rdfs:label "Rechten"@nl ;
	rdf:comment "Rights Statement"@en .

## Classes for persons from Persons In Context

picom:PersonObservation a rdfs:Class ;
        rdfs:label "Persoonsvermelding"@nl ;
        rdf:comment "Persoon zoals geobserveerd in een bron"@nl .
    
picom:PersonReconstruction a rdfs:Class ;
        rdfs:label "Persoonsreconstructie"@nl ;
        rdf:comment "Persoon gemodelleerd op basis van een of meer persoonsvermeldingen"@nl .

<https://data.oorlogsbronnen.nl/oorlogsbronnen-shapes> a owl:Ontology ;
    owl:imports <http://datashapes.org/dash> ;
    rdfs:label "Oorlogsbronnen SHACL Shapes"@nl .

# =================================================================
# BASIS LOGICA (Interne herbruikbare blokken)
# =================================================================

:Base_String          a sh:PropertyShape ; sh:datatype xsd:string .
:Base_IRI             a sh:PropertyShape ; sh:nodeKind sh:IRI .
:Base_Date            a sh:PropertyShape ; sh:datatype xsd:date .
:Base_Integer         a sh:PropertyShape ; sh:datatype xsd:integer .
:Base_StringOrIRI     a sh:PropertyShape ; sh:or ([sh:datatype xsd:string] [sh:nodeKind sh:IRI]) .
:Base_DateOrInteger   a sh:PropertyShape ; sh:or ([sh:datatype xsd:date] [sh:datatype xsd:integer]) .

# =================================================================
# TECHNISCHE BOUWSTENEN (Gekoppeld aan Properties)
# =================================================================

# --- Identificatie en Naamgeving ---
:Rule_name              sh:path schema:name ;          sh:node :Base_String ; sh:minCount 1 ; sh:maxCount 1 .
:Rule_title             sh:path dc:title ;             sh:node :Base_String ; sh:minCount 1 ; sh:maxCount 1 .
:Rule_identifier_dc     sh:path dc:identifier ;        sh:node :Base_String ; sh:minCount 1 ; sh:maxCount 1 .
:Rule_identifier_schema sh:path schema:identifier ;    sh:node :Base_String ; sh:minCount 1 ; sh:maxCount 1 .
:Rule_deceased          sh:path picom:deceased ;       sh:node :Base_String ; sh:maxCount 1 .
:Rule_additionalName    sh:path schema:additionalName ;sh:node :Base_String .
:Rule_alternateName     sh:path schema:alternateName ; sh:node :Base_String .
:Rule_givenName         sh:path schema:givenName ;     sh:node :Base_String .
:Rule_familyName        sh:path schema:familyName ;    sh:node :Base_String .
:Rule_initials          sh:path pnv:initials ;         sh:node :Base_String .

# --- Beschrijving en Categorisering ---
:Rule_description_dc     sh:path dc:description ;      sh:node :Base_String .
:Rule_description_schema sh:path schema:description ;  sh:node :Base_String .
:Rule_caption            sh:path schema:caption ;      sh:node :Base_String ; sh:maxCount 1 .
:Rule_rights             sh:path dc:rights ;           sh:node :Base_String .
:Rule_source             sh:path dc:source ;           sh:node :Base_String .
:Rule_hasOccupation      sh:path schema:hasOccupation ;sh:node :Base_String .
:Rule_type_dc            sh:path dc:type ;             sh:node :Base_String .
:Rule_collection         sh:path dcmit:Collection ;    sh:node :Base_String .
:Rule_keywords           sh:path schema:keywords ;     sh:node :Base_IRI ; sh:class skos:Concept .
:Rule_subject            sh:path dc:subject ;          sh:node :Base_StringOrIRI .
:Rule_about              sh:path schema:about ;        sh:node :Base_StringOrIRI .
:Rule_type               sh:path rdf:type ;             sh:node :Base_IRI .
:Rule_additionalType     sh:path schema:additionalType ;sh:node :Base_IRI .

# --- Data en Tijd ---
:Rule_date               sh:path dc:date ;             sh:node :Base_DateOrInteger ; sh:maxCount 1 .
:Rule_startDate          sh:path schema:startDate ;    sh:node :Base_DateOrInteger ; sh:maxCount 1 .
:Rule_endDate            sh:path schema:endDate ;      sh:node :Base_DateOrInteger ; sh:maxCount 1 .
:Rule_dateCreated        sh:path schema:dateCreated ;   sh:node :Base_Date ; sh:maxCount 1 .
:Rule_dateModified       sh:path schema:dateModified ;  sh:node :Base_Date ; sh:maxCount 1 .
:Rule_birthDate          sh:path schema:birthDate ;     sh:node :Base_Date ; sh:maxCount 1 .
:Rule_deathDate          sh:path schema:deathDate ;     sh:node :Base_Date ; sh:maxCount 1 .
:Rule_datePublished      sh:path schema:datePublished ; sh:node :Base_Date ; sh:maxCount 1 .
:Rule_temporal           sh:path schema:temporal ;      sh:node :Base_String .

# --- Locatie ---
:Rule_birthPlace         sh:path schema:birthPlace ;     sh:node :Base_StringOrIRI ; sh:maxCount 1 .
:Rule_deathPlace         sh:path schema:deathPlace ;     sh:node :Base_StringOrIRI ; sh:maxCount 1 .
:Rule_location           sh:path schema:location ;       sh:node :Base_StringOrIRI .
:Rule_contentLocation    sh:path schema:contentLocation ;sh:node :Base_StringOrIRI .
:Rule_homeLocation       sh:path schema:homeLocation ;   sh:node :Base_StringOrIRI .
:Rule_address            sh:path schema:address ;        sh:node :Base_StringOrIRI .
:Rule_fromLocation       sh:path schema:fromLocation ;   sh:node :Base_StringOrIRI .
:Rule_toLocation         sh:path schema:toLocation ;     sh:node :Base_StringOrIRI .

# --- Personen en Organisaties (Relaties) ---
:Rule_children           sh:path schema:children;       sh:node :Base_IRI ;  sh:or ([ sh:class picom:PersonReconstruction ] [ sh:class picom:PersonObservation ]) .
:Rule_parent             sh:path schema:parent ;        sh:node :Base_IRI ;  sh:or ([ sh:class picom:PersonReconstruction ] [ sh:class picom:PersonObservation ]) .
:Rule_sibling            sh:path schema:sibling ;       sh:node :Base_IRI ;  sh:or ([ sh:class picom:PersonReconstruction ] [ sh:class picom:PersonObservation ]) .
:Rule_actor              sh:path schema:actor ;          sh:node :Base_IRI ; sh:or ([ sh:class picom:PersonReconstruction ] [ sh:class picom:PersonObservation ]) .
:Rule_publisher          sh:path dc:publisher ;         sh:node :Base_IRI  ; sh:class schema:Organization .
:Rule_provider           sh:path schema:provider ;      sh:node :Base_StringOrIRI .
:Rule_creator            sh:path dc:creator ;           sh:node :Base_StringOrIRI .
:Rule_gender             sh:path schema:gender ;        sh:node :Base_StringOrIRI .

# --- Media en Web ---
:Rule_url                sh:path schema:url ;           sh:node :Base_StringOrIRI .
:Rule_contentUrl         sh:path schema:contentUrl ;    sh:node :Base_StringOrIRI .
:Rule_thumbnail          sh:path schema:thumbnail ;     sh:node :Base_StringOrIRI .
:Rule_thumbnailUrl       sh:path schema:thumbnailUrl ;  sh:node :Base_StringOrIRI .
:Rule_image              sh:path schema:image ;         sh:node :Base_IRI .

# --- Structureel en Rechten ---
:Rule_isPartOf           sh:path dct:isPartOf ;         sh:node :Base_IRI .
:Rule_superEvent         sh:path schema:superEvent ;    sh:node :Base_IRI ; sh:class schema:Event .
:Rule_license            sh:path schema:license ;       sh:node :Base_IRI ; sh:class niod:Rights .
:Rule_position           sh:path schema:position ;      sh:node :Base_Integer .

# --- Herkomst en Verwijzingen ---
:Rule_sameAs             sh:path schema:sameAs ;        sh:node :Base_IRI .
:Rule_wasDerivedFrom     sh:path prov:wasDerivedFrom ;  sh:node :Base_IRI ; sh:class picom:PersonObservation .
:Rule_hadPrimarySource   sh:path prov:hadPrimarySource ;sh:node :Base_IRI ; sh:or ([ sh:class prov:Entity ] [ sh:class schema:ArchiveComponent ]) .
:Rule_inDataset          sh:path niod:inDataset ;       sh:node :Base_IRI ; sh:class schema:Dataset .

# =================================================================
# 2. TOEPASSING OP KLASSEN (Context-specifieke labels voor Widoco)
# =================================================================

### --- PERSOONSRECONSTRUCTIE ---
:PersoonReconstructionShape a sh:NodeShape ;
    sh:targetClass picom:PersonReconstruction ;
    sh:name "Persoonsreconstructie"@nl ;
    sh:description "De geaggregeerde en gevalideerde gegevens van een persoon, samengesteld uit één of meerdere persoonsvermeldingen."@nl ;

    # --- Identificatie ---
    sh:property [
        sh:path schema:identifier ;
        sh:name "Identifier"@nl ;
        sh:description "De unieke identifier van persoon."@nl ;
        sh:node :Rule_identifier_schema ;
    ] ;
    sh:property [
        sh:path rdf:type ;
        sh:name "Type entiteit"@nl ;
        sh:description "Classificatie van de entiteit volgens Persons in Context."@nl ;
        sh:node :Rule_type ;
    ] ;

    # --- Naamgeving ---
    sh:property [
        sh:path schema:name ;
        sh:name "Naam"@nl ;
        sh:description "De gestandaardiseerde volledige naam van de persoon."@nl ;
        sh:node :Rule_name ;
    ] ;
    sh:property [
        sh:path schema:alternateName ;
        sh:name "Andere namen"@nl ;
        sh:description "Varianten, aliassen of historische schrijfwijzen van de naam."@nl ;
        sh:node :Rule_alternateName ;
    ] ;

    # --- Levensloop en Status ---
    sh:property [
        sh:path schema:birthDate ;
        sh:name "Geboortedatum"@nl ;
        sh:node :Rule_birthDate ;
    ] ;
    sh:property [
        sh:path schema:birthPlace ;
        sh:name "Geboorteplaats"@nl ;
        sh:node :Rule_birthPlace ;
    ] ;
    sh:property [
        sh:path schema:deathDate ;
        sh:name "Datum van overlijden"@nl ;
        sh:node :Rule_deathDate ;
    ] ;
    sh:property [
        sh:path schema:deathPlace ;
        sh:name "Plaats van overlijden"@nl ;
        sh:node :Rule_deathPlace ;
    ] ;
    sh:property [
        sh:path picom:deceased ;
        sh:name "Overleden status"@nl ;
        sh:description "Indicatie of de persoon is overleden."@nl ;
        sh:node :Rule_deceased ;
    ] ;
    sh:property [
        sh:path schema:gender ;
        sh:name "Geslacht"@nl ;
        sh:node :Rule_gender ;
    ] ;

    # --- Familierelaties ---
    sh:property [
        sh:path schema:children ;
        sh:name "Kinderen"@nl ;
        sh:description "Verwijzing naar de kinderen van deze persoon."@nl ;
        sh:node :Rule_children ;
    ] ;
    sh:property [
        sh:path schema:parent ;
        sh:name "Ouder"@nl ;
        sh:description "Verwijzing naar een ouder van deze persoon."@nl ;
        sh:node :Rule_parent ;
    ] ;
    sh:property [
        sh:path schema:sibling ;
        sh:name "Broer of zus"@nl ;
        sh:description "Verwijzing naar een broer of zus van deze persoon."@nl ;
        sh:node :Rule_sibling ;
    ] ;

    # --- Metadata en Herkomst ---
    sh:property [
        sh:path schema:dateCreated ;
        sh:name "Aanmaakdatum"@nl ;
        sh:description "Datum waarop deze reconstructie voor het eerst is aangemaakt."@nl ;
        sh:node :Rule_dateCreated ;
    ] ;
    sh:property [
        sh:path schema:dateModified ;
        sh:name "Wijzigingsdatum"@nl ;
        sh:description "Datum waarop deze reconstructie voor het laatst is bijgewerkt."@nl ;
        sh:node :Rule_dateModified ;
    ] ;
    sh:property [
        sh:path prov:wasDerivedFrom ;
        sh:name "Afgeleid van"@nl ;
        sh:description "Verwijzing naar de persoonsvermeldingen waaruit deze reconstructie is opgebouwd."@nl ;
        sh:node :Rule_wasDerivedFrom ;
    ] ;
    sh:property [
        sh:path schema:sameAs ;
        sh:name "Andere autoriteit"@nl ;
        sh:description "Externe links naar dezelfde persoon in andere systemen (bijv. Wikidata)."@nl ;
        sh:node :Rule_sameAs ;
    ] ;
    sh:property [
        sh:path schema:keywords ;
        sh:name "Trefwoorden"@nl ;
        sh:description "Categorisering of trefwoorden van toepassing op de persoon (uit de WO2 thesaurus)."@nl ;
        sh:node :Rule_keywords ;
    ] .

### --- PERSOONSVERMELDING ---
:PersoonsvermeldingShape a sh:NodeShape ;
    sh:targetClass picom:PersonObservation ;
    sh:name "Persoonsvermelding"@nl ;
    sh:description "Een observatie of vermelding van een persoon binnen een specifieke historische bron."@nl ;

    # 1. Hergebruik alle regels van PersonReconstruction
    sh:node :PersoonReconstructionShape ;

    # 2. Sluit specifiek uit
    sh:property [
        sh:path prov:wasDerivedFrom ;
        sh:maxCount 0 ;
        sh:name "Afgeleid van (niet toegestaan)"@nl ;
        sh:description "Voor persoonsvermeldingen wordt prov:wasDerivedFrom niet toegestaan."@nl ;
    ] ;

    # 3. Voeg extra properties toe
    # --- Naamgeving ---
    sh:property [
        sh:path schema:givenName ;
        sh:name "Voornaam"@nl ;
        sh:description "De roepnaam of eerste voornaam van de persoon."@nl ;
        sh:node :Rule_givenName ;
    ] ;
    sh:property [
        sh:path schema:familyName ;
        sh:name "Achternaam"@nl ;
        sh:description "De geslachtsnaam, inclusief tussenvoegsels."@nl ;
        sh:node :Rule_familyName ;
    ] ;
    sh:property [
        sh:path pnv:initials ;
        sh:name "Initialen"@nl ;
        sh:description "De voorletters van de persoon."@nl ;
        sh:node :Rule_initials ;
    ] ;

    # --- Kenmerken en Context ---
    sh:property [
        sh:path schema:hasOccupation ;
        sh:name "Beroep of functie"@nl ;
        sh:description "Het beroep of de maatschappelijke rol van de persoon."@nl ;
        sh:node :Rule_hasOccupation ;
    ] ;
    sh:property [
        sh:path schema:address ;
        sh:name "Adresgegevens"@nl ;
        sh:description "Woonplaats of laatst bekende adres."@nl ;
        sh:node :Rule_address ;
    ] ;
    sh:property [
        sh:path prov:hadPrimarySource ;
        sh:name "Primaire bron"@nl ;
        sh:description "De originele bron waaruit deze informatie afkomstig is."@nl ;
        sh:node :Rule_hadPrimarySource ;
    ] ;
    sh:property [
        sh:path schema:description ;
        sh:name "Biografische schets"@nl ;
        sh:description "Een korte beschrijving van de persoon of diens rol tijdens de Tweede Wereldoorlog."@nl ;
        sh:node :Rule_description_schema ;
    ] .

### --- PERSOONLIJKE GEBEURTENISSEN ---
:EventShape a sh:NodeShape ;
    sh:targetClass schema:Event ;
    sh:name "Gebeurtenis"@nl ;
    sh:description ""@nl ;

    # --- Type ---
    sh:property [
        sh:path rdf:type ;
        sh:name "Type entiteit"@nl ;
        sh:description "Classificatie van de entiteit als schema:Event"@nl ;
        sh:node :Rule_type ;
    ] ;
    sh:property [
        sh:path schema:additionalType ;
        sh:name "type gebeurtenis"@nl ;
        sh:description "Classificatie van de gebeurtenis als persoonlijke gebeurtenis uit de WO2 thesaurus"@nl ;
        sh:node :Rule_type ;
    ] ;

    # --- Kenmerken en Context ---
    sh:property [
        sh:path schema:name ;
        sh:name "Naam"@nl ;
        sh:description "De naam van de gebeurtenis."@nl ;
        sh:node :Rule_hasOccupation ;
    ] ;
    sh:property [
        sh:path schema:location ;
        sh:name "Locatie"@nl ;
        sh:node :Rule_location ;
    ] ;
    sh:property [
        sh:path schema:fromLocation ;
        sh:name "Beginlocatie"@nl ;
        sh:node :Rule_fromLocation ;
    ] ;
    sh:property [
        sh:path schema:toLocation ;
        sh:name "Eindlocatie"@nl ;
        sh:node :Rule_toLocation ;
    ] ;
    sh:property [
        sh:path schema:actor ;
        sh:name "Persoon in de gebeurtenis"@nl ;
        sh:node :Rule_actor ;
    ] ;
    sh:property [
        sh:path schema:superEvent ;
        sh:name "Grotere gebeurtenis"@nl ;
        sh:node :Rule_superEvent ;
    ] ;
    sh:property [
        sh:path prov:hadPrimarySource ;
        sh:name "Primaire bron"@nl ;
        sh:description "De originele bron waaruit deze informatie afkomstig is."@nl ;
        sh:node :Rule_hadPrimarySource ;
    ] ;

    # --- Tijd ---
    sh:property [
        sh:path schema:startDate ;
        sh:name "Startdatum"@nl ;
        sh:node :Rule_startDate ;
    ] ;
    sh:property [
        sh:path schema:endDate ;
        sh:name "Einddatum"@nl ;
        sh:node :Rule_endDate ;
    ] .

### --- BRONNEN VOOR PERSONEN ---
:SourceShape a sh:NodeShape ;
    sh:targetClass 
        schema:ArchiveComponent,
        prov:Entity ;
    sh:name "Record waarop de persoonsvermelding is aangetroffen"@nl ;
    sh:description "Archiefstukken, maar ook records uit andere (onderzoeks)datasets en webpagina's kunnen persoonsvermeldingen bevatten. Dit is hiervoor de bronvermelding."@nl ;
    
    sh:property [
        sh:path rdf:type ;
        sh:name "Type entiteit"@nl ;
        sh:description "Classificatie van het record als archiefstuk of anders."@nl ;
        sh:node :Rule_type ;
    ] ;
    sh:property [
        sh:path schema:url ;
        sh:name "Url van de bron"@nl ;
        sh:node :Rule_url ;
    ] ;
    sh:property [
        sh:path niod:inDataset ;
        sh:name "Herkomst van het record"@nl ;
        sh:node :Rule_inDataset ;
    ] .

:SourceShape a sh:NodeShape ;
    sh:targetClass 
        schema:Dataset ;
    sh:name "Dataset waaruit een record afkomstig is"@nl ;
    sh:description "Records  maken altijd onderdeel uit van een dataset."@nl ;
    
    # --- Identificatie ---
    sh:property [
        sh:path schema:identifier ;
        sh:name "Identifier"@nl ;
        sh:description "De unieke identifier van de dataset."@nl ;
        sh:node :Rule_identifier_schema ;
    ] ;
    sh:property [
        sh:path rdf:type ;
        sh:name "Type entiteit"@nl ;
        sh:description "Classificatie van de entiteit als schema:Dataset"@nl ;
        sh:node :Rule_type ;
    ] ;

    # --- Kenmerken en context ---
    sh:property [
        sh:path schema:name ;
        sh:name "Naam van de dataset"@nl ;
        sh:node :Rule_name ;
    ] ;
    sh:property [
        sh:path schema:description ;
        sh:name "Beschrijving van de dataset"@nl ;
        sh:node :Rule_description ;
    ] ;
    sh:property [
        sh:path schema:url ;
        sh:name "Bronverwijzing voor de dataset"@nl ;
        sh:node :Rule_url ;
    ] ;
    sh:property [
        sh:path schema:provider ;
        sh:name "Leverancier van de dataset"@nl ;
        sh:node :Rule_provider ;
    ] .

### --- BRON EN OBJECT TYPEN ---
:CreativeWorkShape a sh:NodeShape ;
    sh:targetClass 
        schema:CreativeWork,
        schema:Article, 
        schema:Newspaper, 
        schema:Book, 
        schema:Photograph, 
        schema:VisualArtwork, 
        schema:Painting, 
        schema:Sculpture, 
        schema:SheetMusic,
        niod:Monument ;
    sh:name "Bronnen en Objecten"@nl ;
    sh:description "Verschillende typen bronnen en objecten die binnen de collectie worden beschreven, zoals artikelen, foto's en kunstwerken."@nl ;
    # --- Identificatie en Basis ---
    sh:property [
        sh:path dc:identifier ;
        sh:name "Identifier (DC)"@nl ;
        sh:node :Rule_identifier_dc ;
    ] ;
    sh:property [
        sh:path dc:title ;
        sh:name "Titel"@nl ;
        sh:node :Rule_title ;
    ] ;
    sh:property [
        sh:path rdf:type ;
        sh:name "Type (RDF)"@nl ;
        sh:node :Rule_type ;
    ] ;
    sh:property [
        sh:path dc:type ;
        sh:name "Type (DC)"@nl ;
        sh:node :Rule_type_dc ;
    ] ;

    # --- Inhoud en Onderwerp ---
    sh:property [
        sh:path dc:description ;
        sh:name "Beschrijving"@nl ;
        sh:node :Rule_description_dc ;
    ] ;
    sh:property [
        sh:path dc:subject ;
        sh:name "Onderwerp"@nl ;
        sh:node :Rule_subject ;
    ] ;
    sh:property [
        sh:path schema:about ;
        sh:name "Betreft entiteit"@nl ;
        sh:node :Rule_about ;
    ] ;
    sh:property [
        sh:path schema:temporal ;
        sh:name "Periodisering"@nl ;
        sh:node :Rule_temporal ;
    ] ;
    sh:property [
        sh:path schema:contentLocation ;
        sh:name "Inhoudelijke locatie"@nl ;
        sh:node :Rule_contentLocation ;
    ] ;

    # --- Creatie en Herkomst ---
    sh:property [
        sh:path dc:creator ;
        sh:name "Maker"@nl ;
        sh:node :Rule_creator ;
    ] ;
    sh:property [
        sh:path dc:publisher ;
        sh:name "Uitgever"@nl ;
        sh:node :Rule_publisher ;
    ] ;
    sh:property [
        sh:path schema:provider ;
        sh:name "Provider"@nl ;
        sh:description "De instelling die het object digitaal beschikbaar stelt."@nl ;
        sh:node :Rule_provider ;
    ] ;
    sh:property [
        sh:path dc:source ;
        sh:name "Bron"@nl ;
        sh:node :Rule_source ;
    ] ;
    sh:property [
        sh:path dcmit:Collection ;
        sh:name "Collectie"@nl ;
        sh:description "De verzameling waar dit object deel van uitmaakt."@nl ;
        sh:node :Rule_collection ;
    ] ;

    # --- Tijd ---
    sh:property [
        sh:path dc:date ;
        sh:name "Datum"@nl ;
        sh:node :Rule_date ;
    ] ;
    sh:property [
        sh:path schema:startDate ;
        sh:name "Startdatum"@nl ;
        sh:node :Rule_startDate ;
    ] ;
    sh:property [
        sh:path schema:endDate ;
        sh:name "Einddatum"@nl ;
        sh:node :Rule_endDate ;
    ] ;

    # --- Visueel ---
    sh:property [
        sh:path schema:thumbnail ;
        sh:name "Thumbnail"@nl ;
        sh:node :Rule_thumbnail ;
    ] .

### --- ARCHIEVEN EN ARCHIEFSTUKKEN (Uitbreiding) ---
:ArchiveShape a sh:NodeShape ;
    sh:targetClass 
        niod:Archive,
        niod:ArchiveFile ;
    sh:name "Archieven en Archiefstukken"@nl ;
    
    # 1. Hergebruik alle regels van CreativeWork
    sh:node :CreativeWorkShape ;

    # 2. Voeg extra properties toe
    sh:property [
        sh:path dct:isPartOf ;
        sh:name "Onderdeel van"@nl ;
        sh:description "Dit archiefstuk is onderdeel van een archiefserie of archief"@nl ;
        sh:node :Rule_isPartOf ;
    ] .

### --- AUDIO EN VIDEO OBJECTEN (Uitbreiding) ---
:MediaShape a sh:NodeShape ;
    sh:targetClass 
        schema:VideoObject,
        schema:AudioObject ;
    sh:name "Audio en Video objecten"@nl ;
    
    # 1. Hergebruik alle regels van CreativeWork
    sh:node :CreativeWorkShape ;

    # 2. Voeg extra properties toe
    sh:property [
        sh:path schema:contentUrl ;
        sh:name "Url van het media object"@nl ;
        sh:node :Rule_contentUrl ;
    ] .

### --- GEBEURTENIS ---
:GebeurtenisShape a sh:NodeShape ;
    sh:targetClass schema:Event ;
    sh:name "Gebeurtenis"@nl ;
    sh:property [
        sh:path schema:name ;
        sh:name "Titel van gebeurtenis"@nl ;
        sh:description "Bijv: 'Transport vanuit Kamp Amersfoort' of 'Razzia van Rotterdam'."@nl ;
        sh:node :TechnicalNameRule ;
    ] ;
    sh:property [
        sh:path schema:datePublished ;
        sh:name "Datum van plaatsvinden"@nl ;
        sh:description "De dag waarop de gebeurtenis startte."@nl ;
        sh:node :TechnicalDateRule ;
    ] .
