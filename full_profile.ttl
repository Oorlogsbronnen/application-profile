    rdfs:label "Verraden"@nl ;
    rdfs:subClassOf schema:Event ;
    rdfs:comment "Verraden worden. Werkwoord om de persoon te beschrijven die verraden is."@nl ;
    rdfs:isDefinedBy <https://data.niod.nl/WO2_Thesaurus/events/6358> .

