	sh:path schema:birthPlace ;
	sh:nodeKind sh:IRI .
:Rule_deathPlace    a sh:PropertyShape ;
	sh:path schema:deathPlace ;
	sh:nodeKind sh:IRI .
:Rule_address       a sh:PropertyShape ;
	sh:path schema:address ;
	sh:datatype xsd:string .
:Rule_fromLocation  a sh:PropertyShape ;
	sh:path schema:fromLocation ;
	sh:nodeKind sh:IRI .
:Rule_toLocation    a sh:PropertyShape ;
	sh:path schema:toLocation ;
	sh:nodeKind sh:IRI .

# --- Personen en Organisaties (Relaties) ---
:Rule_actor         a sh:PropertyShape ;
	sh:path schema:actor ;
	sh:nodeKind sh:IRI .
:Rule_creator       a sh:PropertyShape ;
	sh:path schema:creator ;
	sh:nodeKind sh:IRI .
:Rule_publisher     a sh:PropertyShape ;
	sh:path schema:publisher ;
	sh:nodeKind sh:IRI .
:Rule_maintainer    a sh:PropertyShape ;
	sh:path schema:maintainer ;
	sh:nodeKind sh:IRI .
:Rule_memberOf      a sh:PropertyShape ;
	sh:path schema:memberOf ;
	sh:nodeKind sh:IRI .
:Rule_jobTitle      a sh:PropertyShape ;
	sh:path schema:jobTitle ;
	sh:datatype xsd:string .
:Rule_gender        a sh:PropertyShape ;
	sh:path schema:gender ;
	sh:datatype xsd:string .

# --- Media en Web ---
:Rule_url           a sh:PropertyShape ;
	sh:path schema:url ;
	sh:nodeKind sh:IRI .
:Rule_contentUrl    a sh:PropertyShape ;
	sh:path schema:contentUrl ;
	sh:nodeKind sh:IRI .
:Rule_image         a sh:PropertyShape ;
	sh:path schema:image ;
	sh:nodeKind sh:IRI .
:Rule_thumbnail     a sh:PropertyShape ;
	sh:path schema:thumbnail ;
	sh:nodeKind sh:IRI .
:Rule_thumbnailUrl  a sh:PropertyShape ;
	sh:path schema:thumbnailUrl ;
