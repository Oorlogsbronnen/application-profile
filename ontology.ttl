                                                       rdfs:subClassOf <http://schema.org/CreativeWork> ;
                                                       rdf:comment "Class for interviews segments"@en ;
                                                       rdfs:label "Fragment"@nl .


###  http://data.oorlogsbronnen.nl/model#Monument
<http://data.oorlogsbronnen.nl/model#Monument> rdf:type owl:Class ;
                                               rdfs:subClassOf <http://schema.org/CreativeWork> ;
