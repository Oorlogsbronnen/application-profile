<http://datashapes.org/dash#Service> rdf:type <http://datashapes.org/dash#ShapeClass> ;
                                     <http://datashapes.org/dash#abstract> "true"^^xsd:boolean .


###  http://datashapes.org/dash#ShapeClass
<http://datashapes.org/dash#ShapeClass> rdf:type <http://datashapes.org/dash#ShapeClass> ;
                                        <http://datashapes.org/dash#hidden> "true"^^xsd:boolean .


###  http://datashapes.org/dash#SingleEditor
<http://datashapes.org/dash#SingleEditor> rdf:type <http://datashapes.org/dash#ShapeClass> .


###  http://datashapes.org/dash#SingleLineConstraintComponent
<http://datashapes.org/dash#SingleLineConstraintComponent> rdf:type <http://www.w3.org/ns/shacl#ConstraintComponent> ;
                                                           <http://www.w3.org/ns/shacl#parameter> <http://datashapes.org/dash#SingleLineConstraintComponent-singleLine> ;
                                                           <http://www.w3.org/ns/shacl#validator> _:genid95 ;
                                                           rdfs:comment """A constraint component that can be used to declare that all values that are literals must have a lexical form that contains no line breaks ('\\n' or '\\r').

User interfaces may use the dash:singleLine flag to prefer a text field over a (multi-line) text area.""" ;
                                                           rdfs:label "Single line constraint component" ;
                                                           <http://www.w3.org/ns/shacl#message> "Must not contain line breaks." .

_:genid95 rdf:type <http://www.w3.org/ns/shacl#SPARQLAskValidator> ;
           <http://www.w3.org/ns/shacl#prefixes> <http://datashapes.org/dash> ;
           <http://www.w3.org/ns/shacl#ask> """ASK {
    FILTER (!$singleLine || !isLiteral($value) || (!contains(str($value), '\\n') && !contains(str($value), '\\r')))
}""" .


###  http://datashapes.org/dash#SingleLineConstraintComponent-singleLine
<http://datashapes.org/dash#SingleLineConstraintComponent-singleLine> rdf:type <http://www.w3.org/ns/shacl#Parameter> ;
                                                                      <http://datashapes.org/dash#reifiableBy> <http://datashapes.org/dash#ConstraintReificationShape> ;
                                                                      <http://www.w3.org/ns/shacl#datatype> xsd:boolean ;
                                                                      <http://www.w3.org/ns/shacl#path> <http://datashapes.org/dash#singleLine> ;
                                                                      <http://www.w3.org/ns/shacl#maxCount> 1 ;
                                                                      <http://www.w3.org/ns/shacl#description> "True to state that the lexical form of literal value nodes must not contain any line breaks. False to state that line breaks are explicitly permitted." ;
                                                                      <http://www.w3.org/ns/shacl#name> "single line" .


###  http://datashapes.org/dash#SingleViewer
<http://datashapes.org/dash#SingleViewer> rdf:type <http://datashapes.org/dash#ShapeClass> .


###  http://datashapes.org/dash#Stable
<http://datashapes.org/dash#Stable> rdf:type <http://datashapes.org/dash#APIStatus> ;
                                    rdfs:comment "Features that have been marked stable are deemed of good quality and can be used until marked deprecated." ;
                                    rdfs:label "stable" .


###  http://datashapes.org/dash#StemConstraintComponent
<http://datashapes.org/dash#StemConstraintComponent> rdf:type <http://www.w3.org/ns/shacl#ConstraintComponent> ;
                                                     <http://www.w3.org/ns/shacl#parameter> <http://datashapes.org/dash#StemConstraintComponent-stem> ;
                                                     <http://www.w3.org/ns/shacl#validator> <http://datashapes.org/dash#hasStem> ;
                                                     <http://datashapes.org/dash#staticConstraint> "true"^^xsd:boolean ;
                                                     rdfs:comment "A constraint component that can be used to verify that every value node is an IRI and the IRI starts with a given string value."@en ;
                                                     rdfs:label "Stem constraint component"@en ;
                                                     <http://www.w3.org/ns/shacl#labelTemplate> "Value needs to have stem {$stem}" ;
                                                     <http://www.w3.org/ns/shacl#message> "Value does not have stem {$stem}" .


###  http://datashapes.org/dash#StemConstraintComponent-stem
<http://datashapes.org/dash#StemConstraintComponent-stem> rdf:type <http://www.w3.org/ns/shacl#Parameter> ;
                                                          <http://datashapes.org/dash#reifiableBy> <http://datashapes.org/dash#ConstraintReificationShape> ;
                                                          <http://www.w3.org/ns/shacl#datatype> xsd:string ;
                                                          <http://www.w3.org/ns/shacl#path> <http://datashapes.org/dash#stem> ;
                                                          <http://www.w3.org/ns/shacl#maxCount> 1 ;
                                                          <http://www.w3.org/ns/shacl#description> "If specified then every value node must be an IRI and the IRI must start with the given string value." ;
                                                          <http://www.w3.org/ns/shacl#name> "stem" .


###  http://datashapes.org/dash#StringOrLangString
<http://datashapes.org/dash#StringOrLangString> rdfs:comment "An rdf:List that can be used in property constraints as value for sh:or to indicate that all values of a property must be either xsd:string or rdf:langString." ;
                                                rdfs:label "String or langString" .


###  http://datashapes.org/dash#SubClassEditor
<http://datashapes.org/dash#SubClassEditor> rdf:type <http://datashapes.org/dash#SingleEditor> ;
                                            rdfs:comment "An editor for properties that declare a dash:rootClass. The editor allows selecting either the class itself or one of its subclasses." ;
                                            rdfs:label "Sub-Class editor" .


###  http://datashapes.org/dash#SubSetOfConstraintComponent
<http://datashapes.org/dash#SubSetOfConstraintComponent> rdf:type <http://www.w3.org/ns/shacl#ConstraintComponent> ;
                                                         <http://www.w3.org/ns/shacl#parameter> <http://datashapes.org/dash#SubSetOfConstraintComponent-subSetOf> ;
                                                         <http://www.w3.org/ns/shacl#propertyValidator> _:genid96 ;
                                                         <http://datashapes.org/dash#localConstraint> "true"^^xsd:boolean ;
                                                         rdfs:comment "A constraint component that can be used to state that the set of value nodes must be a subset of the value of a given property." ;
                                                         rdfs:label "Sub set of constraint component" ;
                                                         <http://www.w3.org/ns/shacl#message> "Must be one of the values of {$subSetOf}" .

_:genid96 rdf:type <http://www.w3.org/ns/shacl#SPARQLAskValidator> ;
           <http://www.w3.org/ns/shacl#prefixes> <http://datashapes.org/dash> ;
           <http://www.w3.org/ns/shacl#ask> """ASK {
    $this $subSetOf $value .
}""" .


###  http://datashapes.org/dash#SubSetOfConstraintComponent-subSetOf
<http://datashapes.org/dash#SubSetOfConstraintComponent-subSetOf> rdf:type <http://www.w3.org/ns/shacl#Parameter> ;
                                                                  <http://datashapes.org/dash#editor> <http://datashapes.org/dash#PropertyAutoCompleteEditor> ;
                                                                  <http://datashapes.org/dash#reifiableBy> <http://datashapes.org/dash#ConstraintReificationShape> ;
                                                                  <http://datashapes.org/dash#viewer> <http://datashapes.org/dash#PropertyLabelViewer> ;
                                                                  <http://www.w3.org/ns/shacl#nodeKind> <http://www.w3.org/ns/shacl#IRI> ;
                                                                  <http://www.w3.org/ns/shacl#path> <http://datashapes.org/dash#subSetOf> ;
                                                                  <http://www.w3.org/ns/shacl#description> "Can be used to state that all value nodes must also be values of a specified other property at the same focus node." ;
                                                                  <http://www.w3.org/ns/shacl#name> "sub-set of" .


###  http://datashapes.org/dash#Suggestion
<http://datashapes.org/dash#Suggestion> <http://datashapes.org/dash#abstract> "true"^^xsd:boolean .


###  http://datashapes.org/dash#SuggestionGenerator
<http://datashapes.org/dash#SuggestionGenerator> <http://datashapes.org/dash#abstract> "true"^^xsd:boolean .


###  http://datashapes.org/dash#SymmetricConstraintComponent
<http://datashapes.org/dash#SymmetricConstraintComponent> rdf:type <http://www.w3.org/ns/shacl#ConstraintComponent> ;
                                                          <http://www.w3.org/ns/shacl#parameter> <http://datashapes.org/dash#SymmetricConstraintComponent-symmetric> ;
                                                          <http://www.w3.org/ns/shacl#propertyValidator> _:genid97 ;
                                                          rdfs:comment "A contraint component for property shapes to validate that a property is symmetric. For symmetric properties, if A relates to B then B must relate to A." ;
                                                          rdfs:label "Symmetric constraint component" ;
                                                          <http://www.w3.org/ns/shacl#message> "Symmetric value expected" .

_:genid97 rdf:type <http://www.w3.org/ns/shacl#SPARQLSelectValidator> ;
           <http://www.w3.org/ns/shacl#prefixes> <http://datashapes.org/dash> ;
           <http://www.w3.org/ns/shacl#select> """SELECT $this ?value {
	FILTER ($symmetric) .
	$this $PATH ?value .
	FILTER NOT EXISTS {
    	?value $PATH $this .
	}
}""" .


###  http://datashapes.org/dash#SymmetricConstraintComponent-symmetric
<http://datashapes.org/dash#SymmetricConstraintComponent-symmetric> rdf:type <http://www.w3.org/ns/shacl#Parameter> ;
                                                                    <http://datashapes.org/dash#reifiableBy> <http://datashapes.org/dash#ConstraintReificationShape> ;
                                                                    <http://www.w3.org/ns/shacl#datatype> xsd:boolean ;
                                                                    <http://www.w3.org/ns/shacl#path> <http://datashapes.org/dash#symmetric> ;
                                                                    <http://www.w3.org/ns/shacl#maxCount> 1 ;
                                                                    <http://www.w3.org/ns/shacl#description> "If set to true then if A relates to B then B must relate to A." ;
                                                                    <http://www.w3.org/ns/shacl#name> "symmetric" .


###  http://datashapes.org/dash#TestCase
<http://datashapes.org/dash#TestCase> rdf:type <http://datashapes.org/dash#ShapeClass> ;
                                      <http://datashapes.org/dash#abstract> "true"^^xsd:boolean .


###  http://datashapes.org/dash#TestCaseResult
<http://datashapes.org/dash#TestCaseResult> <http://datashapes.org/dash#abstract> "true"^^xsd:boolean .


###  http://datashapes.org/dash#TestEnvironment
<http://datashapes.org/dash#TestEnvironment> <http://datashapes.org/dash#abstract> "true"^^xsd:boolean .


###  http://datashapes.org/dash#TextAreaEditor
<http://datashapes.org/dash#TextAreaEditor> rdf:type <http://datashapes.org/dash#SingleEditor> ;
                                            rdfs:comment "A multi-line text area to enter the value of a literal." ;
                                            rdfs:label "Text area editor" .


###  http://datashapes.org/dash#TextAreaWithLangEditor
<http://datashapes.org/dash#TextAreaWithLangEditor> rdf:type <http://datashapes.org/dash#SingleEditor> ;
                                                    rdfs:comment "A multi-line text area to enter the value of a literal and a drop down to select a language." ;
                                                    rdfs:label "Text area with lang editor" .


###  http://datashapes.org/dash#TextFieldEditor
<http://datashapes.org/dash#TextFieldEditor> rdf:type <http://datashapes.org/dash#SingleEditor> ;
                                             rdfs:comment """A simple input field to enter the value of a literal, without the ability to change language or datatype.

This is the fallback editor for any literal if no other editors are more suitable.""" ;
                                             rdfs:label "Text field editor" .


###  http://datashapes.org/dash#TextFieldWithLangEditor
<http://datashapes.org/dash#TextFieldWithLangEditor> rdf:type <http://datashapes.org/dash#SingleEditor> ;
                                                     rdfs:comment "A single-line input field to enter the value of a literal and a drop down to select language, which is mandatory unless xsd:string is among the permissible datatypes." ;
                                                     rdfs:label "Text field with lang editor" .


###  http://datashapes.org/dash#URIEditor
<http://datashapes.org/dash#URIEditor> rdf:type <http://datashapes.org/dash#SingleEditor> ;
                                       rdfs:comment "An input field to enter the URI of a resource, e.g. rdfs:seeAlso links or images." ;
                                       rdfs:label "URI editor" .


###  http://datashapes.org/dash#URIViewer
<http://datashapes.org/dash#URIViewer> rdf:type <http://datashapes.org/dash#SingleViewer> ;
                                       rdfs:comment "A Viewer for URI resources, rendering as a hyperlink to that URI. Also includes other ways of interacting with the URI such as opening a nested summary display." ;
                                       rdfs:label "URI viewer" .


###  http://datashapes.org/dash#UniqueValueForClassConstraintComponent
<http://datashapes.org/dash#UniqueValueForClassConstraintComponent> rdf:type <http://www.w3.org/ns/shacl#ConstraintComponent> ;
                                                                    <http://www.w3.org/ns/shacl#parameter> <http://datashapes.org/dash#UniqueValueForClassConstraintComponent-uniqueValueForClass> ;
                                                                    <http://www.w3.org/ns/shacl#propertyValidator> _:genid98 ;
                                                                    rdfs:comment "A constraint component that can be used to state that the values of a property must be unique for all instances of a given class (and its subclasses)." ;
                                                                    rdfs:label "Unique value for class constraint component" ;
                                                                    <http://www.w3.org/ns/shacl#labelTemplate> "Values must be unique among all instances of {?uniqueValueForClass}" .

_:genid98 rdf:type <http://www.w3.org/ns/shacl#SPARQLSelectValidator> ;
           <http://www.w3.org/ns/shacl#prefixes> <http://datashapes.org/dash> ;
           <http://www.w3.org/ns/shacl#select> """SELECT DISTINCT $this ?value ?other
WHERE {
	{
    	$this $PATH ?value .
		?other $PATH ?value .
		FILTER (?other != $this) .
	}
	?other a ?type .
	?type rdfs:subClassOf* $uniqueValueForClass .
}""" ;
           <http://www.w3.org/ns/shacl#message> "Value {?value} must be unique but is also used by {?other}" .


###  http://datashapes.org/dash#UniqueValueForClassConstraintComponent-uniqueValueForClass
<http://datashapes.org/dash#UniqueValueForClassConstraintComponent-uniqueValueForClass> rdf:type <http://www.w3.org/ns/shacl#Parameter> ;
                                                                                        <http://datashapes.org/dash#reifiableBy> <http://datashapes.org/dash#ConstraintReificationShape> ;
                                                                                        <http://www.w3.org/ns/shacl#class> rdfs:Class ;
                                                                                        <http://www.w3.org/ns/shacl#nodeKind> <http://www.w3.org/ns/shacl#IRI> ;
                                                                                        <http://www.w3.org/ns/shacl#path> <http://datashapes.org/dash#uniqueValueForClass> ;
                                                                                        <http://www.w3.org/ns/shacl#description> "States that the values of the property must be unique for all instances of a given class (and its subclasses)." ;
                                                                                        <http://www.w3.org/ns/shacl#name> "unique value for class" .


###  http://datashapes.org/dash#UntrustedHTMLViewer
<http://datashapes.org/dash#UntrustedHTMLViewer> rdf:type <http://datashapes.org/dash#SingleViewer> ;
                                                 rdfs:comment "A Viewer for HTML content from untrusted sources. This viewer will sanitize the HTML before rendering. Any a, button, checkbox, form, hidden, input, img, script, select, style and textarea tags and class and style attributes will be removed." ;
                                                 rdfs:label "Untrusted HTML viewer" .


###  http://datashapes.org/dash#ValidationTestCase
<http://datashapes.org/dash#ValidationTestCase> rdf:type <http://datashapes.org/dash#ShapeClass> ;
                                                <http://datashapes.org/dash#abstract> "true"^^xsd:boolean .


###  http://datashapes.org/dash#ValueTableViewer
<http://datashapes.org/dash#ValueTableViewer> rdf:type <http://datashapes.org/dash#MultiViewer> ;
                                              rdfs:comment "A viewer that renders all values of a given property as a table, with one value per row, and the columns defined by the shape that is the sh:node or sh:class of the property." ;
                                              rdfs:label "Value table viewer" .


###  http://datashapes.org/dash#Viewer
<http://datashapes.org/dash#Viewer> rdf:type <http://datashapes.org/dash#ShapeClass> ;
                                    <http://datashapes.org/dash#abstract> "true"^^xsd:boolean .


###  http://datashapes.org/dash#Widget
<http://datashapes.org/dash#Widget> rdf:type <http://datashapes.org/dash#ShapeClass> ;
                                    <http://datashapes.org/dash#abstract> "true"^^xsd:boolean .


###  http://datashapes.org/dash#all
<http://datashapes.org/dash#all> rdf:type rdfs:Resource ;
                                 rdfs:comment "Represents all users/roles, for example as a possible value of the default view for role property." ;
                                 rdfs:label "all" .


###  http://datashapes.org/dash#closedByTypes
<http://datashapes.org/dash#closedByTypes> rdfs:label "closed by types" .


###  http://datashapes.org/dash#hasClass
<http://datashapes.org/dash#hasClass> rdf:type <http://www.w3.org/ns/shacl#SPARQLAskValidator> ;
                                      <http://www.w3.org/ns/shacl#prefixes> <http://datashapes.org/dash> ;
                                      <http://www.w3.org/ns/shacl#ask> """
		ASK {
			$value rdf:type/rdfs:subClassOf* $class .
		}
		""" ;
                                      rdfs:label "has class" ;
                                      <http://www.w3.org/ns/shacl#message> "Value does not have class {$class}" .


###  http://datashapes.org/dash#hasMaxExclusive
<http://datashapes.org/dash#hasMaxExclusive> rdf:type <http://www.w3.org/ns/shacl#SPARQLAskValidator> ;
                                             <http://www.w3.org/ns/shacl#prefixes> <http://datashapes.org/dash> ;
                                             <http://www.w3.org/ns/shacl#ask> "ASK { FILTER ($value < $maxExclusive) }" ;
                                             rdfs:comment "Checks whether a given node (?value) has a value less than (<) the provided ?maxExclusive. Returns false if this cannot be determined, e.g. because values do not have comparable types." ;
                                             rdfs:label "has max exclusive" .


###  http://datashapes.org/dash#hasMaxInclusive
<http://datashapes.org/dash#hasMaxInclusive> rdf:type <http://www.w3.org/ns/shacl#SPARQLAskValidator> ;
                                             <http://www.w3.org/ns/shacl#prefixes> <http://datashapes.org/dash> ;
                                             <http://www.w3.org/ns/shacl#ask> "ASK { FILTER ($value <= $maxInclusive) }" ;
                                             rdfs:comment "Checks whether a given node (?value) has a value less than or equal to (<=) the provided ?maxInclusive. Returns false if this cannot be determined, e.g. because values do not have comparable types." ;
                                             rdfs:label "has max inclusive" .


###  http://datashapes.org/dash#hasMaxLength
<http://datashapes.org/dash#hasMaxLength> rdf:type <http://www.w3.org/ns/shacl#SPARQLAskValidator> ;
                                          <http://www.w3.org/ns/shacl#prefixes> <http://datashapes.org/dash> ;
                                          <http://www.w3.org/ns/shacl#ask> """
		ASK {
			FILTER (STRLEN(str($value)) <= $maxLength) .
		}
		""" ;
                                          rdfs:comment "Checks whether a given string (?value) has a length within a given maximum string length." ;
                                          rdfs:label "has max length" .


###  http://datashapes.org/dash#hasMinExclusive
<http://datashapes.org/dash#hasMinExclusive> rdf:type <http://www.w3.org/ns/shacl#SPARQLAskValidator> ;
                                             <http://www.w3.org/ns/shacl#prefixes> <http://datashapes.org/dash> ;
                                             <http://www.w3.org/ns/shacl#ask> "ASK { FILTER ($value > $minExclusive) }" ;
                                             rdfs:comment "Checks whether a given node (?value) has value greater than (>) the provided ?minExclusive. Returns false if this cannot be determined, e.g. because values do not have comparable types." ;
                                             rdfs:label "has min exclusive" .


###  http://datashapes.org/dash#hasMinInclusive
<http://datashapes.org/dash#hasMinInclusive> rdf:type <http://www.w3.org/ns/shacl#SPARQLAskValidator> ;
                                             <http://www.w3.org/ns/shacl#prefixes> <http://datashapes.org/dash> ;
                                             <http://www.w3.org/ns/shacl#ask> "ASK { FILTER ($value >= $minInclusive) }" ;
                                             rdfs:comment "Checks whether a given node (?value) has value greater than or equal to (>=) the provided ?minInclusive. Returns false if this cannot be determined, e.g. because values do not have comparable types." ;
                                             rdfs:label "has min inclusive" .


###  http://datashapes.org/dash#hasMinLength
<http://datashapes.org/dash#hasMinLength> rdf:type <http://www.w3.org/ns/shacl#SPARQLAskValidator> ;
                                          <http://www.w3.org/ns/shacl#prefixes> <http://datashapes.org/dash> ;
                                          <http://www.w3.org/ns/shacl#ask> """
		ASK {
			FILTER (STRLEN(str($value)) >= $minLength) .
		}
		""" ;
                                          rdfs:comment "Checks whether a given string (?value) has a length within a given minimum string length." ;
                                          rdfs:label "has min length" .


###  http://datashapes.org/dash#hasNodeKind
<http://datashapes.org/dash#hasNodeKind> rdf:type <http://www.w3.org/ns/shacl#SPARQLAskValidator> ;
                                         <http://www.w3.org/ns/shacl#prefixes> <http://datashapes.org/dash> ;
                                         <http://www.w3.org/ns/shacl#ask> """
		ASK {
			FILTER ((isIRI($value) && $nodeKind IN ( sh:IRI, sh:BlankNodeOrIRI, sh:IRIOrLiteral ) ) ||
				(isLiteral($value) && $nodeKind IN ( sh:Literal, sh:BlankNodeOrLiteral, sh:IRIOrLiteral ) ) ||
				(isBlank($value)   && $nodeKind IN ( sh:BlankNode, sh:BlankNodeOrIRI, sh:BlankNodeOrLiteral ) )) .
		}
		""" ;
                                         rdfs:comment "Checks whether a given node (?value) has a given sh:NodeKind (?nodeKind). For example, sh:hasNodeKind(42, sh:Literal) = true." ;
                                         rdfs:label "has node kind" .


###  http://datashapes.org/dash#hasPattern
<http://datashapes.org/dash#hasPattern> rdf:type <http://www.w3.org/ns/shacl#SPARQLAskValidator> ;
                                        <http://www.w3.org/ns/shacl#prefixes> <http://datashapes.org/dash> ;
                                        <http://www.w3.org/ns/shacl#ask> "ASK { FILTER (!isBlank($value) && IF(bound($flags), regex(str($value), $pattern, $flags), regex(str($value), $pattern))) }" ;
                                        rdfs:comment "Checks whether the string representation of a given node (?value) matches a given regular expression (?pattern). Returns false if the value is a blank node." ;
                                        rdfs:label "has pattern" .


###  http://datashapes.org/dash#hasRootClass
<http://datashapes.org/dash#hasRootClass> rdf:type <http://www.w3.org/ns/shacl#SPARQLAskValidator> ;
                                          <http://www.w3.org/ns/shacl#prefixes> <http://datashapes.org/dash> ;
                                          <http://www.w3.org/ns/shacl#ask> """ASK {
    $value rdfs:subClassOf* $rootClass .
}""" ;
                                          rdfs:label "has root class" .


###  http://datashapes.org/dash#hasStem
<http://datashapes.org/dash#hasStem> rdf:type <http://www.w3.org/ns/shacl#SPARQLAskValidator> ;
                                     <http://www.w3.org/ns/shacl#prefixes> <http://datashapes.org/dash> ;
                                     <http://www.w3.org/ns/shacl#ask> "ASK { FILTER (isIRI($value) && STRSTARTS(str($value), $stem)) }" ;
                                     rdfs:comment "Checks whether a given node is an IRI starting with a given stem." ;
                                     rdfs:label "has stem" .


###  http://datashapes.org/dash#isDeactivated
<http://datashapes.org/dash#isDeactivated> rdf:type <http://www.w3.org/ns/shacl#SPARQLFunction> ;
                                           <http://datashapes.org/dash#apiStatus> <http://datashapes.org/dash#Stable> ;
                                           <http://www.w3.org/ns/shacl#parameter> _:genid99 ;
                                           <http://www.w3.org/ns/shacl#prefixes> <http://datashapes.org/dash> ;
                                           <http://www.w3.org/ns/shacl#returnType> xsd:boolean ;
                                           <http://www.w3.org/ns/shacl#ask> """ASK {
    ?constraintOrShape sh:deactivated true .
}""" ;
                                           rdfs:comment "Checks whether a given shape or constraint has been marked as \"deactivated\" using sh:deactivated." ;
                                           rdfs:label "is deactivated" .

_:genid99 rdf:type <http://www.w3.org/ns/shacl#Parameter> ;
           <http://www.w3.org/ns/shacl#path> <http://datashapes.org/dash#constraintOrShape> ;
           <http://www.w3.org/ns/shacl#description> "The sh:Constraint or sh:Shape to test." ;
           <http://www.w3.org/ns/shacl#name> "constraint or shape" .


###  http://datashapes.org/dash#isIn
<http://datashapes.org/dash#isIn> rdf:type <http://www.w3.org/ns/shacl#SPARQLAskValidator> ;
                                  <http://www.w3.org/ns/shacl#prefixes> <http://datashapes.org/dash> ;
                                  <http://www.w3.org/ns/shacl#ask> """
		ASK {
			GRAPH $shapesGraph {
				$in (rdf:rest*)/rdf:first $value .
			}
		}
		""" ;
                                  rdfs:label "is in" .


###  http://datashapes.org/dash#isLanguageIn
<http://datashapes.org/dash#isLanguageIn> rdf:type <http://www.w3.org/ns/shacl#SPARQLAskValidator> ;
                                          <http://www.w3.org/ns/shacl#prefixes> <http://datashapes.org/dash> ;
                                          <http://www.w3.org/ns/shacl#ask> """
		ASK {
			BIND (lang($value) AS ?valueLang) .
			FILTER EXISTS {
				GRAPH $shapesGraph {
					$languageIn (rdf:rest*)/rdf:first ?lang .
				    FILTER (langMatches(?valueLang, ?lang))
				} }
		}
		""" ;
                                          rdfs:label "is language in" .


###  http://datashapes.org/dash#isNodeKindBlankNode
<http://datashapes.org/dash#isNodeKindBlankNode> rdf:type <http://www.w3.org/ns/shacl#SPARQLFunction> ;
                                                 <http://datashapes.org/dash#apiStatus> <http://datashapes.org/dash#Stable> ;
                                                 <http://www.w3.org/ns/shacl#parameter> _:genid100 ;
                                                 <http://www.w3.org/ns/shacl#prefixes> <http://datashapes.org/dash> ;
                                                 <http://www.w3.org/ns/shacl#returnType> xsd:boolean ;
                                                 <http://datashapes.org/dash#cachable> "true"^^xsd:boolean ;
                                                 <http://datashapes.org/dash#contextFree> "true"^^xsd:boolean ;
                                                 <http://www.w3.org/ns/shacl#ask> """ASK {
	FILTER ($nodeKind IN ( sh:BlankNode, sh:BlankNodeOrIRI, sh:BlankNodeOrLiteral ))
}""" ;
                                                 rdfs:comment "Checks if a given sh:NodeKind is one that includes BlankNodes." ;
                                                 rdfs:label "is NodeKind BlankNode" .

_:genid100 rdf:type <http://www.w3.org/ns/shacl#Parameter> ;
            <http://www.w3.org/ns/shacl#class> <http://www.w3.org/ns/shacl#NodeKind> ;
            <http://www.w3.org/ns/shacl#nodeKind> <http://www.w3.org/ns/shacl#IRI> ;
            <http://www.w3.org/ns/shacl#path> <http://datashapes.org/dash#nodeKind> ;
            <http://www.w3.org/ns/shacl#description> "The sh:NodeKind to check." ;
            <http://www.w3.org/ns/shacl#name> "node kind" .


###  http://datashapes.org/dash#isNodeKindIRI
<http://datashapes.org/dash#isNodeKindIRI> rdf:type <http://www.w3.org/ns/shacl#SPARQLFunction> ;
                                           <http://datashapes.org/dash#apiStatus> <http://datashapes.org/dash#Stable> ;
                                           <http://www.w3.org/ns/shacl#parameter> _:genid101 ;
                                           <http://www.w3.org/ns/shacl#prefixes> <http://datashapes.org/dash> ;
                                           <http://www.w3.org/ns/shacl#returnType> xsd:boolean ;
                                           <http://datashapes.org/dash#cachable> "true"^^xsd:boolean ;
                                           <http://datashapes.org/dash#contextFree> "true"^^xsd:boolean ;
                                           <http://www.w3.org/ns/shacl#ask> """ASK {
	FILTER ($nodeKind IN ( sh:IRI, sh:BlankNodeOrIRI, sh:IRIOrLiteral ))
}""" ;
                                           rdfs:comment "Checks if a given sh:NodeKind is one that includes IRIs." ;
                                           rdfs:label "is NodeKind IRI" .

_:genid101 rdf:type <http://www.w3.org/ns/shacl#Parameter> ;
            <http://www.w3.org/ns/shacl#class> <http://www.w3.org/ns/shacl#NodeKind> ;
            <http://www.w3.org/ns/shacl#nodeKind> <http://www.w3.org/ns/shacl#IRI> ;
            <http://www.w3.org/ns/shacl#path> <http://datashapes.org/dash#nodeKind> ;
            <http://www.w3.org/ns/shacl#description> "The sh:NodeKind to check." ;
            <http://www.w3.org/ns/shacl#name> "node kind" .


###  http://datashapes.org/dash#isNodeKindLiteral
<http://datashapes.org/dash#isNodeKindLiteral> rdf:type <http://www.w3.org/ns/shacl#SPARQLFunction> ;
                                               <http://datashapes.org/dash#apiStatus> <http://datashapes.org/dash#Stable> ;
                                               <http://www.w3.org/ns/shacl#parameter> _:genid102 ;
                                               <http://www.w3.org/ns/shacl#prefixes> <http://datashapes.org/dash> ;
                                               <http://www.w3.org/ns/shacl#returnType> xsd:boolean ;
                                               <http://datashapes.org/dash#cachable> "true"^^xsd:boolean ;
                                               <http://datashapes.org/dash#contextFree> "true"^^xsd:boolean ;
                                               <http://www.w3.org/ns/shacl#ask> """ASK {
	FILTER ($nodeKind IN ( sh:Literal, sh:BlankNodeOrLiteral, sh:IRIOrLiteral ))
}""" ;
                                               rdfs:comment "Checks if a given sh:NodeKind is one that includes Literals." ;
                                               rdfs:label "is NodeKind Literal" .

_:genid102 rdf:type <http://www.w3.org/ns/shacl#Parameter> ;
            <http://www.w3.org/ns/shacl#class> <http://www.w3.org/ns/shacl#NodeKind> ;
            <http://www.w3.org/ns/shacl#nodeKind> <http://www.w3.org/ns/shacl#IRI> ;
            <http://www.w3.org/ns/shacl#path> <http://datashapes.org/dash#nodeKind> ;
            <http://www.w3.org/ns/shacl#description> "The sh:NodeKind to check." ;
            <http://www.w3.org/ns/shacl#name> "node kind" .


###  http://datashapes.org/dash#isSubClassOf
<http://datashapes.org/dash#isSubClassOf> rdf:type <http://www.w3.org/ns/shacl#SPARQLFunction> ;
                                          <http://datashapes.org/dash#apiStatus> <http://datashapes.org/dash#Stable> ;
                                          <http://www.w3.org/ns/shacl#parameter> <http://datashapes.org/dash#isSubClassOf-subclass> ,
                                                                                 <http://datashapes.org/dash#isSubClassOf-superclass> ;
                                          <http://www.w3.org/ns/shacl#prefixes> <http://datashapes.org/dash> ;
                                          <http://www.w3.org/ns/shacl#returnType> xsd:boolean ;
                                          <http://www.w3.org/ns/shacl#ask> """ASK {
    $subclass rdfs:subClassOf* $superclass .
}""" ;
                                          rdfs:comment "Returns true if a given class (first argument) is a subclass of a given other class (second argument), or identical to that class. This is equivalent to an rdfs:subClassOf* check." ;
                                          rdfs:label "is subclass of" .


###  http://datashapes.org/dash#isSubClassOf-subclass
<http://datashapes.org/dash#isSubClassOf-subclass> rdf:type <http://www.w3.org/ns/shacl#Parameter> ;
                                                   <http://www.w3.org/ns/shacl#class> rdfs:Class ;
                                                   <http://www.w3.org/ns/shacl#path> <http://datashapes.org/dash#subclass> ;
                                                   <http://www.w3.org/ns/shacl#description> "The (potential) subclass." ;
                                                   <http://www.w3.org/ns/shacl#name> "subclass" .


###  http://datashapes.org/dash#isSubClassOf-superclass
<http://datashapes.org/dash#isSubClassOf-superclass> rdf:type <http://www.w3.org/ns/shacl#Parameter> ;
                                                     <http://www.w3.org/ns/shacl#class> rdfs:Class ;
                                                     <http://www.w3.org/ns/shacl#path> <http://datashapes.org/dash#superclass> ;
                                                     <http://www.w3.org/ns/shacl#order> 1 ;
                                                     <http://www.w3.org/ns/shacl#description> "The (potential) superclass." ;
                                                     <http://www.w3.org/ns/shacl#name> "superclass" .


