###  http://www.w3.org/ns/shacl#AbstractResult
<http://www.w3.org/ns/shacl#AbstractResult> <http://datashapes.org/dash#abstract> "true"^^xsd:boolean .


###  http://www.w3.org/ns/shacl#ClassConstraintComponent
<http://www.w3.org/ns/shacl#ClassConstraintComponent> <http://www.w3.org/ns/shacl#validator> <http://datashapes.org/dash#hasClass> ;
                                                      <http://www.w3.org/ns/shacl#labelTemplate> "Value needs to have class {$class}" .


###  http://www.w3.org/ns/shacl#ClosedConstraintComponent
<http://www.w3.org/ns/shacl#ClosedConstraintComponent> <http://www.w3.org/ns/shacl#nodeValidator> _:genid108 ;
                                                       <http://datashapes.org/dash#localConstraint> "true"^^xsd:boolean ;
                                                       <http://www.w3.org/ns/shacl#labelTemplate> "Closed shape: only the enumerated properties can be used" .

_:genid108 rdf:type <http://www.w3.org/ns/shacl#SPARQLSelectValidator> ;
            <http://www.w3.org/ns/shacl#prefixes> <http://datashapes.org/dash> ;
            <http://www.w3.org/ns/shacl#select> """
		SELECT $this (?predicate AS ?path) ?value
		WHERE {
			{
				FILTER ($closed) .
			}
			$this ?predicate ?value .
			FILTER (NOT EXISTS {
				GRAPH $shapesGraph {
					$currentShape sh:property/sh:path ?predicate .
				}
			} && (!bound($ignoredProperties) || NOT EXISTS {
				GRAPH $shapesGraph {
					$ignoredProperties rdf:rest*/rdf:first ?predicate .
				}
			}))
		}
""" ;
            <http://www.w3.org/ns/shacl#message> "Predicate {?path} is not allowed (closed shape)" .


###  http://www.w3.org/ns/shacl#DatatypeConstraintComponent
<http://www.w3.org/ns/shacl#DatatypeConstraintComponent> <http://datashapes.org/dash#staticConstraint> "true"^^xsd:boolean ;
                                                         <http://www.w3.org/ns/shacl#labelTemplate> "Values must have datatype {$datatype}" ;
                                                         <http://www.w3.org/ns/shacl#message> "Value does not have datatype {$datatype}" .


###  http://www.w3.org/ns/shacl#DisjointConstraintComponent
<http://www.w3.org/ns/shacl#DisjointConstraintComponent> <http://www.w3.org/ns/shacl#validator> _:genid109 ;
                                                         <http://datashapes.org/dash#localConstraint> "true"^^xsd:boolean .

_:genid109 rdf:type <http://www.w3.org/ns/shacl#SPARQLAskValidator> ;
            <http://www.w3.org/ns/shacl#prefixes> <http://datashapes.org/dash> ;
            <http://www.w3.org/ns/shacl#ask> """
		ASK {
			FILTER NOT EXISTS {
				$this $disjoint $value .
			}
		}
		""" ;
            <http://www.w3.org/ns/shacl#message> "Property must not share any values with {$disjoint}" .


###  http://www.w3.org/ns/shacl#EqualsConstraintComponent
<http://www.w3.org/ns/shacl#EqualsConstraintComponent> <http://www.w3.org/ns/shacl#nodeValidator> _:genid110 ;
                                                       <http://www.w3.org/ns/shacl#propertyValidator> _:genid111 ;
                                                       <http://datashapes.org/dash#localConstraint> "true"^^xsd:boolean ;
                                                       <http://www.w3.org/ns/shacl#message> "Must have same values as {$equals}" .

_:genid110 rdf:type <http://www.w3.org/ns/shacl#SPARQLSelectValidator> ;
            <http://www.w3.org/ns/shacl#prefixes> <http://datashapes.org/dash> ;
            <http://www.w3.org/ns/shacl#select> """
		SELECT DISTINCT $this ?value
		WHERE {
			{
				FILTER NOT EXISTS { $this $equals $this }
				BIND ($this AS ?value) .
			}
			UNION
			{
				$this $equals ?value .
				FILTER (?value != $this) .
			}
		}
		""" .

_:genid111 rdf:type <http://www.w3.org/ns/shacl#SPARQLSelectValidator> ;
            <http://www.w3.org/ns/shacl#prefixes> <http://datashapes.org/dash> ;
            <http://www.w3.org/ns/shacl#select> """
		SELECT DISTINCT $this ?value
		WHERE {
			{
				$this $PATH ?value .
				MINUS {
					$this $equals ?value .
				}
			}
			UNION
			{
				$this $equals ?value .
				MINUS {
					$this $PATH ?value .
				}
			}
		}
		""" .


###  http://www.w3.org/ns/shacl#Function
<http://www.w3.org/ns/shacl#Function> <http://datashapes.org/dash#abstract> "true"^^xsd:boolean .


###  http://www.w3.org/ns/shacl#HasValueConstraintComponent
<http://www.w3.org/ns/shacl#HasValueConstraintComponent> <http://www.w3.org/ns/shacl#nodeValidator> _:genid112 ;
                                                         <http://www.w3.org/ns/shacl#propertyValidator> _:genid113 ;
                                                         <http://datashapes.org/dash#localConstraint> "true"^^xsd:boolean ;
                                                         <http://www.w3.org/ns/shacl#labelTemplate> "Must have value {$hasValue}" .

_:genid112 rdf:type <http://www.w3.org/ns/shacl#SPARQLAskValidator> ;
            <http://www.w3.org/ns/shacl#prefixes> <http://datashapes.org/dash> ;
            <http://www.w3.org/ns/shacl#ask> """ASK {
    FILTER ($value = $hasValue)
}""" ;
            <http://www.w3.org/ns/shacl#message> "Value must be {$hasValue}" .

_:genid113 rdf:type <http://www.w3.org/ns/shacl#SPARQLSelectValidator> ;
            <http://www.w3.org/ns/shacl#prefixes> <http://datashapes.org/dash> ;
            <http://www.w3.org/ns/shacl#select> """
		SELECT $this
		WHERE {
			FILTER NOT EXISTS { $this $PATH $hasValue }
		}
		""" ;
            <http://www.w3.org/ns/shacl#message> "Missing expected value {$hasValue}" .


###  http://www.w3.org/ns/shacl#InConstraintComponent
<http://www.w3.org/ns/shacl#InConstraintComponent> <http://www.w3.org/ns/shacl#validator> <http://datashapes.org/dash#isIn> ;
                                                   <http://datashapes.org/dash#localConstraint> "true"^^xsd:boolean ;
                                                   <http://www.w3.org/ns/shacl#labelTemplate> "Value must be in {$in}" ;
                                                   <http://www.w3.org/ns/shacl#message> "Value is not in {$in}" .


###  http://www.w3.org/ns/shacl#LanguageInConstraintComponent
<http://www.w3.org/ns/shacl#LanguageInConstraintComponent> <http://www.w3.org/ns/shacl#validator> <http://datashapes.org/dash#isLanguageIn> ;
                                                           <http://datashapes.org/dash#localConstraint> "true"^^xsd:boolean ;
                                                           <http://www.w3.org/ns/shacl#labelTemplate> "Language must match any of {$languageIn}" ;
                                                           <http://www.w3.org/ns/shacl#message> "Language does not match any of {$languageIn}" .


###  http://www.w3.org/ns/shacl#LessThanConstraintComponent
<http://www.w3.org/ns/shacl#LessThanConstraintComponent> <http://www.w3.org/ns/shacl#propertyValidator> _:genid114 ;
                                                         <http://datashapes.org/dash#localConstraint> "true"^^xsd:boolean ;
                                                         <http://www.w3.org/ns/shacl#message> "Value is not < value of {$lessThan}" .

_:genid114 rdf:type <http://www.w3.org/ns/shacl#SPARQLSelectValidator> ;
            <http://www.w3.org/ns/shacl#prefixes> <http://datashapes.org/dash> ;
            <http://www.w3.org/ns/shacl#select> """
		SELECT $this ?value
		WHERE {
			$this $PATH ?value .
			$this $lessThan ?otherValue .
			BIND (?value < ?otherValue AS ?result) .
			FILTER (!bound(?result) || !(?result)) .
		}
		""" .


###  http://www.w3.org/ns/shacl#LessThanOrEqualsConstraintComponent
<http://www.w3.org/ns/shacl#LessThanOrEqualsConstraintComponent> <http://www.w3.org/ns/shacl#propertyValidator> _:genid115 ;
                                                                 <http://datashapes.org/dash#localConstraint> "true"^^xsd:boolean ;
                                                                 <http://www.w3.org/ns/shacl#message> "Value is not <= value of {$lessThanOrEquals}" .

_:genid115 rdf:type <http://www.w3.org/ns/shacl#SPARQLSelectValidator> ;
            <http://www.w3.org/ns/shacl#prefixes> <http://datashapes.org/dash> ;
            <http://www.w3.org/ns/shacl#select> """
		SELECT DISTINCT $this ?value
		WHERE {
			$this $PATH ?value .
			$this $lessThanOrEquals ?otherValue .
			BIND (?value <= ?otherValue AS ?result) .
			FILTER (!bound(?result) || !(?result)) .
		}
""" .


###  http://www.w3.org/ns/shacl#MaxCountConstraintComponent
<http://www.w3.org/ns/shacl#MaxCountConstraintComponent> <http://www.w3.org/ns/shacl#propertyValidator> _:genid116 ;
                                                         <http://datashapes.org/dash#localConstraint> "true"^^xsd:boolean ;
                                                         <http://www.w3.org/ns/shacl#labelTemplate> "Must not have more than {$maxCount} values" ;
                                                         <http://www.w3.org/ns/shacl#message> "More than {$maxCount} values" .

_:genid116 rdf:type <http://www.w3.org/ns/shacl#SPARQLSelectValidator> ;
            <http://www.w3.org/ns/shacl#prefixes> <http://datashapes.org/dash> ;
            <http://www.w3.org/ns/shacl#select> """
		SELECT $this
		WHERE {
			$this $PATH ?value .
		}
		GROUP BY $this
		HAVING (COUNT(DISTINCT ?value) > $maxCount)
		""" .


###  http://www.w3.org/ns/shacl#MaxExclusiveConstraintComponent
<http://www.w3.org/ns/shacl#MaxExclusiveConstraintComponent> <http://www.w3.org/ns/shacl#validator> <http://datashapes.org/dash#hasMaxExclusive> ;
                                                             <http://datashapes.org/dash#staticConstraint> "true"^^xsd:boolean ;
                                                             <http://www.w3.org/ns/shacl#labelTemplate> "Value must be < {$maxExclusive}" ;
                                                             <http://www.w3.org/ns/shacl#message> "Value is not < {$maxExclusive}" .


###  http://www.w3.org/ns/shacl#MaxInclusiveConstraintComponent
<http://www.w3.org/ns/shacl#MaxInclusiveConstraintComponent> <http://www.w3.org/ns/shacl#validator> <http://datashapes.org/dash#hasMaxInclusive> ;
                                                             <http://datashapes.org/dash#staticConstraint> "true"^^xsd:boolean ;
                                                             <http://www.w3.org/ns/shacl#labelTemplate> "Value must be <= {$maxInclusive}" ;
                                                             <http://www.w3.org/ns/shacl#message> "Value is not <= {$maxInclusive}" .


###  http://www.w3.org/ns/shacl#MaxLengthConstraintComponent
<http://www.w3.org/ns/shacl#MaxLengthConstraintComponent> <http://www.w3.org/ns/shacl#validator> <http://datashapes.org/dash#hasMaxLength> ;
                                                          <http://datashapes.org/dash#staticConstraint> "true"^^xsd:boolean ;
                                                          <http://www.w3.org/ns/shacl#labelTemplate> "Value must not have more than {$maxLength} characters" ;
                                                          <http://www.w3.org/ns/shacl#message> "Value has more than {$maxLength} characters" .


###  http://www.w3.org/ns/shacl#MinCountConstraintComponent
<http://www.w3.org/ns/shacl#MinCountConstraintComponent> <http://www.w3.org/ns/shacl#propertyValidator> _:genid117 ;
                                                         <http://datashapes.org/dash#localConstraint> "true"^^xsd:boolean ;
                                                         <http://www.w3.org/ns/shacl#labelTemplate> "Must have at least {$minCount} values" ;
                                                         <http://www.w3.org/ns/shacl#message> "Fewer than {$minCount} values" .

_:genid117 rdf:type <http://www.w3.org/ns/shacl#SPARQLSelectValidator> ;
            <http://www.w3.org/ns/shacl#prefixes> <http://datashapes.org/dash> ;
            <http://www.w3.org/ns/shacl#select> """
		SELECT $this
		WHERE {
			OPTIONAL {
				$this $PATH ?value .
			}
		}
		GROUP BY $this
		HAVING (COUNT(DISTINCT ?value) < $minCount)
		""" .


###  http://www.w3.org/ns/shacl#MinExclusiveConstraintComponent
<http://www.w3.org/ns/shacl#MinExclusiveConstraintComponent> <http://www.w3.org/ns/shacl#validator> <http://datashapes.org/dash#hasMinExclusive> ;
                                                             <http://datashapes.org/dash#staticConstraint> "true"^^xsd:boolean ;
                                                             <http://www.w3.org/ns/shacl#labelTemplate> "Value must be > {$minExclusive}" ;
                                                             <http://www.w3.org/ns/shacl#message> "Value is not > {$minExclusive}" .


###  http://www.w3.org/ns/shacl#MinInclusiveConstraintComponent
<http://www.w3.org/ns/shacl#MinInclusiveConstraintComponent> <http://www.w3.org/ns/shacl#validator> <http://datashapes.org/dash#hasMinInclusive> ;
                                                             <http://datashapes.org/dash#staticConstraint> "true"^^xsd:boolean ;
                                                             <http://www.w3.org/ns/shacl#labelTemplate> "Value must be >= {$minInclusive}" ;
                                                             <http://www.w3.org/ns/shacl#message> "Value is not >= {$minInclusive}" .


###  http://www.w3.org/ns/shacl#MinLengthConstraintComponent
<http://www.w3.org/ns/shacl#MinLengthConstraintComponent> <http://www.w3.org/ns/shacl#validator> <http://datashapes.org/dash#hasMinLength> ;
                                                          <http://datashapes.org/dash#staticConstraint> "true"^^xsd:boolean ;
                                                          <http://www.w3.org/ns/shacl#labelTemplate> "Value must have less than {$minLength} characters" ;
                                                          <http://www.w3.org/ns/shacl#message> "Value has less than {$minLength} characters" .


###  http://www.w3.org/ns/shacl#NodeKindConstraintComponent
<http://www.w3.org/ns/shacl#NodeKindConstraintComponent> <http://www.w3.org/ns/shacl#validator> <http://datashapes.org/dash#hasNodeKind> ;
                                                         <http://datashapes.org/dash#staticConstraint> "true"^^xsd:boolean ;
                                                         <http://www.w3.org/ns/shacl#labelTemplate> "Value must have node kind {$nodeKind}" ;
                                                         <http://www.w3.org/ns/shacl#message> "Value does not have node kind {$nodeKind}" .


###  http://www.w3.org/ns/shacl#Parameterizable
<http://www.w3.org/ns/shacl#Parameterizable> <http://datashapes.org/dash#abstract> "true"^^xsd:boolean .


###  http://www.w3.org/ns/shacl#PatternConstraintComponent
<http://www.w3.org/ns/shacl#PatternConstraintComponent> <http://www.w3.org/ns/shacl#validator> <http://datashapes.org/dash#hasPattern> ;
                                                        <http://datashapes.org/dash#staticConstraint> "true"^^xsd:boolean ;
                                                        <http://www.w3.org/ns/shacl#labelTemplate> "Value must match pattern \"{$pattern}\"" ;
                                                        <http://www.w3.org/ns/shacl#message> "Value does not match pattern \"{$pattern}\"" .


###  http://www.w3.org/ns/shacl#Rule
<http://www.w3.org/ns/shacl#Rule> <http://datashapes.org/dash#abstract> "true"^^xsd:boolean .


###  http://www.w3.org/ns/shacl#Rules
<http://www.w3.org/ns/shacl#Rules> rdf:type rdfs:Resource ;
                                   rdfs:comment "The SHACL rules entailment regime." ;
                                   rdfs:label "SHACL Rules" ;
                                   rdfs:seeAlso <https://www.w3.org/TR/shacl-af/#Rules> .


###  http://www.w3.org/ns/shacl#SPARQLExecutable
<http://www.w3.org/ns/shacl#SPARQLExecutable> <http://datashapes.org/dash#abstract> "true"^^xsd:boolean .


###  http://www.w3.org/ns/shacl#Shape
<http://www.w3.org/ns/shacl#Shape> <http://datashapes.org/dash#abstract> "true"^^xsd:boolean .


###  http://www.w3.org/ns/shacl#Target
<http://www.w3.org/ns/shacl#Target> <http://datashapes.org/dash#abstract> "true"^^xsd:boolean .


###  http://www.w3.org/ns/shacl#TargetType
<http://www.w3.org/ns/shacl#TargetType> <http://datashapes.org/dash#abstract> "true"^^xsd:boolean .


###  http://www.w3.org/ns/shacl#UniqueLangConstraintComponent
<http://www.w3.org/ns/shacl#UniqueLangConstraintComponent> <http://www.w3.org/ns/shacl#propertyValidator> _:genid118 ;
                                                           <http://datashapes.org/dash#localConstraint> "true"^^xsd:boolean ;
                                                           <http://www.w3.org/ns/shacl#labelTemplate> "No language can be used more than once" ;
                                                           <http://www.w3.org/ns/shacl#message> "Language \"{?lang}\" used more than once" .

_:genid118 rdf:type <http://www.w3.org/ns/shacl#SPARQLSelectValidator> ;
            <http://www.w3.org/ns/shacl#prefixes> <http://datashapes.org/dash> ;
            <http://www.w3.org/ns/shacl#select> """
		SELECT DISTINCT $this ?lang
		WHERE {
			{
				FILTER sameTerm($uniqueLang, true) .
			}
			$this $PATH ?value .
			BIND (lang(?value) AS ?lang) .
			FILTER (bound(?lang) && ?lang != \"\") .
			FILTER EXISTS {
				$this $PATH ?otherValue .
				FILTER (?otherValue != ?value && ?lang = lang(?otherValue)) .
			}
		}
		""" .


###  http://www.w3.org/ns/shacl#Validator
<http://www.w3.org/ns/shacl#Validator> <http://datashapes.org/dash#abstract> "true"^^xsd:boolean .


