@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.w3.org/2002/07/owl#> .

[ rdf:type owl:Ontology
 ] .

#################################################################
#    Annotation properties
#################################################################

###  http://schema.org/actor
<http://schema.org/actor> rdf:type owl:AnnotationProperty .


###  http://schema.org/image
<http://schema.org/image> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/1999/02/22-rdf-syntax-ns#comment
rdf:comment rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/shacl#datatype
<http://www.w3.org/ns/shacl#datatype> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/shacl#description
<http://www.w3.org/ns/shacl#description> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/shacl#maxCount
<http://www.w3.org/ns/shacl#maxCount> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/shacl#minCount
<http://www.w3.org/ns/shacl#minCount> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/shacl#name
<http://www.w3.org/ns/shacl#name> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/shacl#node
<http://www.w3.org/ns/shacl#node> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/shacl#nodeKind
<http://www.w3.org/ns/shacl#nodeKind> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/shacl#path
<http://www.w3.org/ns/shacl#path> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/shacl#property
<http://www.w3.org/ns/shacl#property> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/shacl#targetClass
<http://www.w3.org/ns/shacl#targetClass> rdf:type owl:AnnotationProperty .


###  https://data.niod.nl/genoemde
<https://data.niod.nl/genoemde> rdf:comment "Een persoon die genoemd wordt bij een bekendmaking"@nl ;
                                rdfs:label "genoemde"@nl ;
                                rdf:type owl:AnnotationProperty ;
                                rdfs:subPropertyOf <http://schema.org/actor> .


###  https://data.niod.nl/imageIIIF
<https://data.niod.nl/imageIIIF> rdf:comment "IIIF manifest van afbeeldingen die bij de bron beschikbaar zijn in IIIF formaat"@nl ;
                                 rdfs:label "IIIF Manifest"@nl ;
                                 rdf:type owl:AnnotationProperty ;
                                 rdfs:subPropertyOf <http://schema.org/image> .


###  https://data.niod.nl/opdrachtgever
<https://data.niod.nl/opdrachtgever> rdf:comment "Een persoon die de opdrachtgever was van een bekendmaking"@nl ;
                                     rdfs:label "opdrachtgever"@nl ;
                                     rdf:type owl:AnnotationProperty ;
                                     rdfs:subPropertyOf <http://schema.org/actor> .


###  https://data.niod.nl/slachtoffer
<https://data.niod.nl/slachtoffer> rdf:comment "Een persoon die slachtoffer was in een gebeurtenis"@nl ;
                                   rdfs:label "slachtoffer"@nl ;
                                   rdf:type owl:AnnotationProperty ;
                                   rdfs:subPropertyOf <http://schema.org/actor> .


#################################################################
#    Classes
#################################################################

###  http://schema.org/CreativeWork
<http://schema.org/CreativeWork> rdf:type owl:Class ;
                                 rdfs:label "Object"@nl .


###  http://schema.org/Event
<http://schema.org/Event> rdf:type owl:Class .


###  http://schema.org/ImageObject
<http://schema.org/ImageObject> rdf:type owl:Class ;
                                rdfs:subClassOf <https://data.niod.nl/Afbeelding> ;
                                rdfs:label "Afbeelding"@nl .


###  http://schema.org/Photograph
<http://schema.org/Photograph> rdf:type owl:Class ;
                               rdfs:subClassOf <https://data.niod.nl/Afbeelding> ;
                               rdfs:label "Foto"@nl .


###  http://schema.org/SheetMusic
<http://schema.org/SheetMusic> rdf:type owl:Class ;
                               rdfs:subClassOf <https://data.niod.nl/Afbeelding> ;
                               rdfs:label "Bladmuziek"@nl .


###  http://schema.org/VisualArtwork
<http://schema.org/VisualArtwork> rdf:type owl:Class ;
                                  rdfs:subClassOf <https://data.niod.nl/Afbeelding> ;
                                  rdfs:label "Kunstwerk"@nl .


###  http://schema.org/WebPage
<http://schema.org/WebPage> rdf:type owl:Class ;
                            rdfs:subClassOf <https://data.niod.nl/Webpagina> .


###  http://www.w3.org/2004/02/skos/core#Concept
<http://www.w3.org/2004/02/skos/core#Concept> rdf:type owl:Class ;
                                              rdfs:subClassOf <https://data.niod.nl/Webpagina> .


###  http://www.w3.org/ns/shacl#NodeShape
<http://www.w3.org/ns/shacl#NodeShape> rdf:type owl:Class .


###  http://www.w3.org/ns/shacl#PropertyShape
<http://www.w3.org/ns/shacl#PropertyShape> rdf:type owl:Class .


###  https://data.niod.nl/Afbeelding
<https://data.niod.nl/Afbeelding> rdf:type owl:Class ;
                                  rdfs:subClassOf <http://schema.org/CreativeWork> ;
                                  rdf:comment "Superclass of all collection objects with a visuel element."@en ;
                                  rdfs:label "Afbeelding"@nl .


###  https://data.niod.nl/Afgepakt
<https://data.niod.nl/Afgepakt> rdf:type owl:Class ;
                                rdfs:subClassOf <http://schema.org/Event> ;
                                rdfs:comment "Afgepakt is de term voor de persoonlijke gebeurtenis waarbij roerende of onroerende bezittingen afgenomen worden van de eigenaar."@nl ;
                                rdfs:isDefinedBy <https://data.niod.nl/WO2_Thesaurus/19486> ;
                                rdfs:label "Afgepakt"@nl .


