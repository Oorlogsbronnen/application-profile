@prefix : <https://data.oorlogsbronnen.nl/oorlogsbronnen-shapes#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://data.oorlogsbronnen.nl/oorlogsbronnen-shapes#> .

<https://data.oorlogsbronnen.nl/oorlogsbronnen-shapes> rdf:type owl:Ontology ;
                                                        owl:imports <http://datashapes.org/dash> ;
                                                        rdfs:label "Oorlogsbronnen SHACL Shapes"@nl .

#################################################################
#    Annotation properties
#################################################################

###  http://data.oorlogsbronnen.nl/model#imageIIIF
<http://data.oorlogsbronnen.nl/model#imageIIIF> rdf:comment "IIIF manifest van afbeeldingen die bij de bron beschikbaar zijn in IIIF formaat"@nl ;
                                                rdfs:label "IIIF Manifest"@nl ;
                                                rdf:type owl:AnnotationProperty ;
                                                rdfs:subPropertyOf <http://schema.org/image> .


###  http://datashapes.org/dash#defaultViewForRole
<http://datashapes.org/dash#defaultViewForRole> rdfs:comment "Links a node shape with the roles for which it shall be used as default view. User interfaces can use these values to select how to present a given RDF resource. The values of this property are URIs representing a group of users or agents. There is a dedicated URI dash:all representing all users." ;
                                                rdfs:label "default view for role" ;
                                                rdfs:domain <http://www.w3.org/ns/shacl#NodeShape> .


###  http://datashapes.org/dash#expectedResult
<http://datashapes.org/dash#expectedResult> rdfs:comment "The expected result(s) of a test case. The value range of this property is different for each kind of test cases." ;
                                            rdfs:label "expected result" ;
                                            rdfs:domain <http://datashapes.org/dash#TestCase> .


###  http://datashapes.org/dash#readOnly
<http://datashapes.org/dash#readOnly> rdfs:comment "Used as a hint for user interfaces that values of the associated property should not be editable. The values of this may be the boolean literals true or false or, more generally, a SHACL node expression that must evaluate to true or false." ;
                                      rdfs:label "read only" ;
                                      rdfs:domain <http://www.w3.org/ns/shacl#PropertyShape> .


###  http://datashapes.org/dash#shapeScript
<http://datashapes.org/dash#shapeScript> rdfs:label "shape script" ;
                                         rdfs:domain <http://www.w3.org/ns/shacl#NodeShape> .


###  http://datashapes.org/dash#suggestionGroup
<http://datashapes.org/dash#suggestionGroup> rdfs:comment "Can be used to link a suggestion with the group identifier to which it belongs. By default this is a link to the dash:SuggestionGenerator, but in principle this could be any value." ;
                                             rdfs:label "suggestion" ;
                                             rdfs:domain <http://datashapes.org/dash#Suggestion> .


###  http://schema.org/actor
<http://schema.org/actor> rdf:type owl:AnnotationProperty .


###  http://schema.org/image
<http://schema.org/image> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/1999/02/22-rdf-syntax-ns#comment
rdf:comment rdf:type owl:AnnotationProperty .


###  https://data.niod.nl/genoemde
<https://data.niod.nl/genoemde> rdf:comment "Een persoon die genoemd wordt bij een bekendmaking"@nl ;
                                rdfs:label "genoemde"@nl ;
                                rdf:type owl:AnnotationProperty ;
                                rdfs:subPropertyOf <http://schema.org/actor> .


###  https://data.niod.nl/opdrachtgever
<https://data.niod.nl/opdrachtgever> rdf:comment "Een persoon die de opdrachtgever was van een bekendmaking"@nl ;
                                     rdfs:label "opdrachtgever"@nl ;
                                     rdf:type owl:AnnotationProperty ;
                                     rdfs:subPropertyOf <http://schema.org/actor> .


###  https://data.niod.nl/slachtoffer
<https://data.niod.nl/slachtoffer> rdf:comment "Een persoon die slachtoffer was in een gebeurtenis"@nl ;
                                   rdfs:label "slachtoffer"@nl ;
                                   rdf:type owl:AnnotationProperty ;
                                   rdfs:subPropertyOf <http://schema.org/actor> .


#################################################################
#    Object Properties
#################################################################

###  http://datashapes.org/dash#actionGroup
<http://datashapes.org/dash#actionGroup> rdfs:domain <http://datashapes.org/dash#Action> ;
                                         rdfs:range <http://datashapes.org/dash#ActionGroup> ;
                                         rdfs:comment "Links an Action with the ActionGroup that it should be arranged in." ;
                                         rdfs:label "action group" .


###  http://datashapes.org/dash#addedTriple
<http://datashapes.org/dash#addedTriple> rdfs:domain <http://datashapes.org/dash#GraphUpdate> ;
                                         rdfs:range rdf:Statement ;
                                         rdfs:comment "May link a dash:GraphUpdate with one or more triples (represented as instances of rdf:Statement) that should be added to fix the source of the result." ;
                                         rdfs:label "added triple" .


###  http://datashapes.org/dash#apiStatus
<http://datashapes.org/dash#apiStatus> rdfs:range <http://datashapes.org/dash#APIStatus> ;
                                       rdfs:comment "Defines how and whether the associated feature is part of an external API. APIs may be implemented as (REST) web services, via GraphQL or ADS Script APIs." ;
                                       rdfs:label "API status" .


###  http://datashapes.org/dash#applicableToClass
<http://datashapes.org/dash#applicableToClass> rdfs:domain <http://www.w3.org/ns/shacl#Shape> ;
                                               rdfs:range rdfs:Class ;
                                               rdfs:comment "Can be used to state that a shape is applicable to instances of a given class. This is a softer statement than \"target class\": a target means that all instances of the class must conform to the shape. Being applicable to simply means that the shape may apply to (some) instances of the class. This information can be used by algorithms or humans." ;
                                               rdfs:label "applicable to class" .


###  http://datashapes.org/dash#coExistsWith
<http://datashapes.org/dash#coExistsWith> rdfs:range rdf:Property .


###  http://datashapes.org/dash#deletedTriple
<http://datashapes.org/dash#deletedTriple> rdfs:domain <http://datashapes.org/dash#GraphUpdate> ;
                                           rdfs:range rdf:Statement ;
                                           rdfs:comment "May link a dash:GraphUpdate result with one or more triples (represented as instances of rdf:Statement) that should be deleted to fix the source of the result." ;
                                           rdfs:label "deleted triple" .


###  http://datashapes.org/dash#dependencyPredicate
<http://datashapes.org/dash#dependencyPredicate> rdfs:range rdf:Property ;
                                                 rdfs:comment "Can be used in dash:js node expressions to enumerate the predicates that the computation of the values may depend on. This can be used by clients to determine whether an edit requires re-computation of values on a form or elsewhere. For example, if the dash:js is something like \"focusNode.firstName + focusNode.lastName\" then the dependency predicates should be ex:firstName and ex:lastName." ;
                                                 rdfs:label "dependency predicate" .


###  http://datashapes.org/dash#editor
<http://datashapes.org/dash#editor> rdfs:domain <http://www.w3.org/ns/shacl#PropertyShape> ;
                                    rdfs:range <http://datashapes.org/dash#Editor> ;
                                    rdfs:comment "Can be used to link a property shape with an editor, to state a preferred editing widget in user interfaces." ;
                                    rdfs:label "editor" .


###  http://datashapes.org/dash#hasValueIn
<http://datashapes.org/dash#hasValueIn> rdfs:range rdf:List .


###  http://datashapes.org/dash#hasValueWithClass
<http://datashapes.org/dash#hasValueWithClass> rdfs:range rdfs:Class .


###  http://datashapes.org/dash#propertySuggestionGenerator
<http://datashapes.org/dash#propertySuggestionGenerator> rdfs:domain <http://www.w3.org/ns/shacl#ConstraintComponent> ;
                                                         rdfs:range <http://datashapes.org/dash#SuggestionGenerator> ;
                                                         rdfs:comment "Links the constraint component with instances of dash:SuggestionGenerator that may be used to produce suggestions for a given validation result that was produced by a property constraint." ;
                                                         rdfs:label "property suggestion generator" .


###  http://datashapes.org/dash#reifiableBy
<http://datashapes.org/dash#reifiableBy> rdfs:domain <http://www.w3.org/ns/shacl#PropertyShape> ;
                                         rdfs:range <http://www.w3.org/ns/shacl#NodeShape> .


###  http://datashapes.org/dash#resourceAction
<http://datashapes.org/dash#resourceAction> rdfs:domain rdfs:Class ;
                                            rdfs:range <http://datashapes.org/dash#ResourceAction> ;
                                            rdfs:comment "Links a class with the Resource Actions that can be applied to instances of that class." ;
                                            rdfs:label "resource action" .


###  http://datashapes.org/dash#shape
<http://datashapes.org/dash#shape> rdfs:range <http://www.w3.org/ns/shacl#Shape> ;
                                   rdfs:comment "States that a subject resource has a given shape. This property can, for example, be used to capture results of SHACL validation on static data." ;
                                   rdfs:label "shape" .


###  http://datashapes.org/dash#suggestion
<http://datashapes.org/dash#suggestion> rdfs:domain <http://www.w3.org/ns/shacl#AbstractResult> ;
                                        rdfs:range <http://datashapes.org/dash#Suggestion> ;
                                        rdfs:comment "Can be used to link a result with one or more suggestions on how to address or improve the underlying issue." ;
                                        rdfs:label "suggestion" .


###  http://datashapes.org/dash#suggestionGenerator
<http://datashapes.org/dash#suggestionGenerator> rdfs:range <http://datashapes.org/dash#SuggestionGenerator> ;
                                                 rdfs:comment "Links a sh:SPARQLConstraint or sh:JSConstraint with instances of dash:SuggestionGenerator that may be used to produce suggestions for a given validation result that was produced by the constraint." ;
                                                 rdfs:label "suggestion generator" .


###  http://datashapes.org/dash#viewer
<http://datashapes.org/dash#viewer> rdfs:domain <http://www.w3.org/ns/shacl#PropertyShape> ;
                                    rdfs:range <http://datashapes.org/dash#Viewer> ;
                                    rdfs:comment "Can be used to link a property shape with a viewer, to state a preferred viewing widget in user interfaces." ;
                                    rdfs:label "viewer" .


#################################################################
#    Data properties
#################################################################

###  http://datashapes.org/dash#abstract
<http://datashapes.org/dash#abstract> rdfs:domain rdfs:Class ;
                                      rdfs:range xsd:boolean ;
                                      rdfs:comment "Indicates that a class is \"abstract\" and cannot be used in asserted rdf:type triples. Only non-abstract subclasses of abstract classes should be instantiated directly." ;
                                      rdfs:label "abstract" .


###  http://datashapes.org/dash#actionIconClass
<http://datashapes.org/dash#actionIconClass> rdfs:domain <http://datashapes.org/dash#Action> ;
                                             rdfs:range xsd:string ;
                                             rdfs:comment "The (CSS) class of an Action for display purposes alongside the label." ;
                                             rdfs:label "action icon class" .


###  http://datashapes.org/dash#cachable
<http://datashapes.org/dash#cachable> rdfs:domain <http://www.w3.org/ns/shacl#Function> ;
                                      rdfs:range xsd:boolean ;
                                      rdfs:comment "If set to true then the results of the SHACL function can be cached in between invocations with the same arguments. In other words, they are stateless and do not depend on triples in any graph, or the current time stamp etc." ;
                                      rdfs:label "cachable" .


###  http://datashapes.org/dash#composite
<http://datashapes.org/dash#composite> rdfs:domain <http://www.w3.org/ns/shacl#PropertyShape> ;
                                       rdfs:range xsd:boolean ;
                                       rdfs:comment "Can be used to indicate that a property/path represented by a property constraint represents a composite relationship. In a composite relationship, the life cycle of a \"child\" object (value of the property/path) depends on the \"parent\" object (focus node). If the parent gets deleted, then the child objects should be deleted, too. Tools may use dash:composite (if set to true) to implement cascading delete operations." ;
                                       rdfs:label "composite" .


###  http://datashapes.org/dash#contextFree
<http://datashapes.org/dash#contextFree> rdfs:range xsd:boolean ;
                                         rdfs:comment "Used to mark certain parameterizables as context-free, meaning that the outcome of a process does not depend on the currently active query graph." ;
                                         rdfs:label "context-free" .


###  http://datashapes.org/dash#defaultLang
<http://datashapes.org/dash#defaultLang> rdfs:domain owl:Ontology ;
                                         rdfs:range xsd:string ;
                                         rdfs:comment "Can be used to annotate a graph (usually the owl:Ontology) with the default language that tools should suggest for new literal values. For example, predominantly English graphs should have \"en\" as default language." ;
                                         rdfs:label "default language" .


###  http://datashapes.org/dash#expectedResultIsJSON
<http://datashapes.org/dash#expectedResultIsJSON> rdfs:range xsd:boolean ;
                                                  rdfs:comment "A flag to indicate that the expected result represents a JSON string. If set to true, then tests would compare JSON structures (regardless of whitespaces) instead of actual syntax." ;
                                                  rdfs:label "expected result is JSON" .


###  http://datashapes.org/dash#expectedResultIsTTL
<http://datashapes.org/dash#expectedResultIsTTL> rdfs:domain <http://datashapes.org/dash#TestCase> ;
                                                 rdfs:range xsd:boolean ;
                                                 rdfs:comment "A flag to indicate that the expected result represents an RDF graph encoded as a Turtle file. If set to true, then tests would compare graphs instead of actual syntax." ;
                                                 rdfs:label "expected result is Turtle" .


###  http://datashapes.org/dash#fixed
<http://datashapes.org/dash#fixed> rdfs:domain <http://www.w3.org/ns/shacl#ValidationResult> ;
                                   rdfs:range xsd:boolean ;
                                   rdfs:comment "Can be used to mark that certain validation results have already been fixed." ;
                                   rdfs:label "fixed" .


###  http://datashapes.org/dash#height
<http://datashapes.org/dash#height> rdfs:range xsd:integer ;
                                    rdfs:comment "The height." ;
                                    rdfs:label "height" .


###  http://datashapes.org/dash#hidden
<http://datashapes.org/dash#hidden> rdfs:domain <http://www.w3.org/ns/shacl#PropertyShape> ;
                                    rdfs:range xsd:boolean ;
                                    rdfs:comment "Properties marked as hidden do not appear in user interfaces, yet remain part of the shape for other purposes such as validation and scripting or GraphQL schema generation." ;
                                    rdfs:label "hidden" .


###  http://datashapes.org/dash#index
<http://datashapes.org/dash#index> rdfs:range xsd:integer ;
                                   rdfs:label "index" .


###  http://datashapes.org/dash#indexed
<http://datashapes.org/dash#indexed> rdfs:domain <http://www.w3.org/ns/shacl#PropertyShape> ;
                                     rdfs:range xsd:boolean .


###  http://datashapes.org/dash#js
<http://datashapes.org/dash#js> rdfs:domain <http://datashapes.org/dash#Script> ;
                                rdfs:range xsd:string ;
                                rdfs:comment "The JavaScript source code of a Script." ;
                                rdfs:label "JavaScript source code" .


###  http://datashapes.org/dash#localConstraint
<http://datashapes.org/dash#localConstraint> rdfs:domain <http://www.w3.org/ns/shacl#ConstraintComponent> ;
                                             rdfs:range xsd:boolean ;
                                             rdfs:comment """Can be set to true for those constraint components where the validation does not require to visit any other triples than the shape definitions and the direct property values of the focus node mentioned in the property constraints. Examples of this include sh:minCount and sh:hasValue.

Constraint components that are marked as such can be optimized by engines, e.g. they can be evaluated client-side at form submission time, without having to make a round-trip to a server, assuming the client has downloaded a complete snapshot of the resource.

Any component marked with dash:staticConstraint is also a dash:localConstraint.""" ;
                                             rdfs:label "local constraint" .


###  http://datashapes.org/dash#mimeTypes
<http://datashapes.org/dash#mimeTypes> rdfs:domain <http://www.w3.org/ns/shacl#PropertyShape> ;
                                       rdfs:range xsd:string ;
                                       rdfs:comment """For file-typed properties, this can be used to specify the expected/allowed mime types of its values. This can be used, for example, to limit file input boxes or file selectors. If multiple values are allowed then they need to be separated by commas.

Example values are listed at https://developer.mozilla.org/en-US/docs/Web/HTTP/Basics_of_HTTP/MIME_types/Common_types""" ;
                                       rdfs:label "mime types" .


###  http://datashapes.org/dash#neverMaterialize
<http://datashapes.org/dash#neverMaterialize> rdfs:domain <http://www.w3.org/ns/shacl#PropertyShape> ;
                                              rdfs:range xsd:boolean ;
                                              rdfs:comment "If set to true at a property shape then any sh:values and sh:defaultValue rules of this property will be ignored when 'all inferences' are computed. This is useful for property values that shall only be computed for individual focus nodes (e.g. when a user visits a resource) but not for large inference runs." ;
                                              rdfs:label "never materialize" .


###  http://datashapes.org/dash#onAllValues
<http://datashapes.org/dash#onAllValues> rdfs:range xsd:boolean ;
                                         rdfs:comment "If set to true for a ScriptConstraint or ScriptValidator, then the associated script will receive all value nodes at once, as a value of the variable values. By default (or false), the script is called for each value node individually." ;
                                         rdfs:label "on all values" .


###  http://datashapes.org/dash#singleLine
<http://datashapes.org/dash#singleLine> rdfs:range xsd:boolean .


###  http://datashapes.org/dash#staticConstraint
<http://datashapes.org/dash#staticConstraint> rdfs:domain <http://www.w3.org/ns/shacl#ConstraintComponent> ;
                                              rdfs:range xsd:boolean ;
                                              rdfs:comment """Can be set to true for those constraint components where the validation does not require to visit any other triples than the parameters. Examples of this include sh:datatype or sh:nodeKind, where no further triples need to be queried to determine the result.

Constraint components that are marked as such can be optimized by engines, e.g. they can be evaluated client-side at form submission time, without having to make a round-trip to a server.""" ;
                                              rdfs:label "static constraint" .


###  http://datashapes.org/dash#stem
<http://datashapes.org/dash#stem> rdfs:range xsd:string .


###  http://datashapes.org/dash#suggestionConfidence
<http://datashapes.org/dash#suggestionConfidence> rdfs:domain <http://datashapes.org/dash#Suggestion> ;
                                                  rdfs:range xsd:decimal ;
                                                  rdfs:comment "An optional confidence between 0% and 100%. Suggestions with 100% confidence are strongly recommended. Can be used to sort recommended updates." ;
                                                  rdfs:label "suggestion confidence" .


###  http://datashapes.org/dash#validateShapes
<http://datashapes.org/dash#validateShapes> rdfs:domain <http://datashapes.org/dash#GraphValidationTestCase> ;
                                            rdfs:range xsd:boolean ;
                                            rdfs:comment "True to also validate the shapes itself (i.e. parameter declarations)." ;
                                            rdfs:label "validate shapes" .


###  http://datashapes.org/dash#width
<http://datashapes.org/dash#width> rdfs:range xsd:integer ;
                                   rdfs:comment "The width." ;
                                   rdfs:label "width" .


###  http://datashapes.org/dash#x
<http://datashapes.org/dash#x> rdfs:range xsd:integer ;
                               rdfs:comment "The x position." ;
                               rdfs:label "x" .


###  http://datashapes.org/dash#y
<http://datashapes.org/dash#y> rdfs:range xsd:integer ;
                               rdfs:comment "The y position." ;
                               rdfs:label "y" .


###  http://www.w3.org/ns/shacl#order
<http://www.w3.org/ns/shacl#order> rdfs:range xsd:decimal .


#################################################################
#    Classes
#################################################################

###  http://data.oorlogsbronnen.nl/model#Afbeelding
<http://data.oorlogsbronnen.nl/model#Afbeelding> rdf:type owl:Class ;
                                                 rdfs:subClassOf <http://schema.org/CreativeWork> ;
                                                 rdf:comment "Superclass of all collection objects with a visuel element."@en ;
                                                 rdfs:label "Afbeelding"@nl .


###  http://data.oorlogsbronnen.nl/model#Archiefmateriaal
<http://data.oorlogsbronnen.nl/model#Archiefmateriaal> rdf:type owl:Class ;
                                                       rdfs:subClassOf <http://schema.org/CreativeWork> ;
                                                       rdf:comment "Class for all archivematerial"@en ;
                                                       rdfs:label "Archiefmateriaal"@nl .


###  http://data.oorlogsbronnen.nl/model#Archive
<http://data.oorlogsbronnen.nl/model#Archive> rdf:type owl:Class ;
                                              rdfs:subClassOf <http://data.oorlogsbronnen.nl/model#Archiefmateriaal> ,
                                                              <http://schema.org/CreativeWork> ;
                                              rdf:comment "Class for an archive"@en ;
                                              rdfs:label "Archief"@nl .


###  http://data.oorlogsbronnen.nl/model#ArchiveFile
<http://data.oorlogsbronnen.nl/model#ArchiveFile> rdf:type owl:Class ;
                                                  rdfs:subClassOf <http://data.oorlogsbronnen.nl/model#Archiefmateriaal> ,
                                                                  <https://data.niod.nl/Archive> ;
                                                  rdf:comment "Class for archival documents"@en ;
                                                  rdfs:label "Archiefstuk"@nl .


###  http://data.oorlogsbronnen.nl/model#ArchiveSeries
<http://data.oorlogsbronnen.nl/model#ArchiveSeries> rdf:type owl:Class ;
                                                    rdfs:subClassOf <http://data.oorlogsbronnen.nl/model#Archiefmateriaal> ,
                                                                    <https://data.niod.nl/Archive> ;
                                                    rdf:comment "Class for a collection of archival documents"@en ;
                                                    rdfs:label "Archiefreeks"@nl .


###  http://data.oorlogsbronnen.nl/model#Bekendmaking
<http://data.oorlogsbronnen.nl/model#Bekendmaking> rdf:type owl:Class ;
                                                   rdfs:subClassOf <https://data.niod.nl/Afbeelding> .


###  http://data.oorlogsbronnen.nl/model#Certificate
<http://data.oorlogsbronnen.nl/model#Certificate> rdf:type owl:Class ;
                                                  rdfs:subClassOf <http://schema.org/CreativeWork> ;
                                                  rdf:comment "Class for archival certificates"@en ;
                                                  rdfs:label "Akte"@nl .


###  http://data.oorlogsbronnen.nl/model#Interview
<http://data.oorlogsbronnen.nl/model#Interview> rdf:type owl:Class ;
                                                rdfs:subClassOf <http://schema.org/CreativeWork> ;
                                                rdf:comment "Class for interviews"@en ;
                                                rdfs:label "Interview"@nl .


###  http://data.oorlogsbronnen.nl/model#InterviewSegment
<http://data.oorlogsbronnen.nl/model#InterviewSegment> rdf:type owl:Class ;
                                                       rdfs:subClassOf <http://schema.org/CreativeWork> ;
                                                       rdf:comment "Class for interviews segments"@en ;
                                                       rdfs:label "Fragment"@nl .


###  http://data.oorlogsbronnen.nl/model#Monument
<http://data.oorlogsbronnen.nl/model#Monument> rdf:type owl:Class ;
                                               rdfs:subClassOf <http://schema.org/CreativeWork> ;
                                               rdf:comment "Class for monuments"@en ;
                                               rdfs:label "Monument"@nl .


###  http://data.oorlogsbronnen.nl/model#Rights
<http://data.oorlogsbronnen.nl/model#Rights> rdf:type owl:Class ;
                                             rdf:comment "Rights Statement"@en ;
                                             rdfs:label "Rechten"@nl .


###  http://data.oorlogsbronnen.nl/model#Webpagina
<http://data.oorlogsbronnen.nl/model#Webpagina> rdf:type owl:Class ;
                                                rdf:comment "Class for all web content created by Oorlogsbronnen"@en ;
                                                rdfs:label "Webpagina"@nl .


###  http://datashapes.org/dash#APIStatus
<http://datashapes.org/dash#APIStatus> rdf:type owl:Class ;
                                       rdfs:subClassOf rdfs:Resource .


###  http://datashapes.org/dash#Action
<http://datashapes.org/dash#Action> rdfs:subClassOf <http://datashapes.org/dash#Script> ,
                                                    <http://www.w3.org/ns/shacl#Parameterizable> .


###  http://datashapes.org/dash#ActionGroup
<http://datashapes.org/dash#ActionGroup> rdfs:subClassOf rdfs:Resource .


###  http://datashapes.org/dash#ActionTestCase
<http://datashapes.org/dash#ActionTestCase> rdfs:subClassOf <http://datashapes.org/dash#TestCase> .


###  http://datashapes.org/dash#AllObjectsTarget
<http://datashapes.org/dash#AllObjectsTarget> rdfs:subClassOf <http://www.w3.org/ns/shacl#Target> .


###  http://datashapes.org/dash#AllSubjectsTarget
<http://datashapes.org/dash#AllSubjectsTarget> rdfs:subClassOf <http://www.w3.org/ns/shacl#Target> .


###  http://datashapes.org/dash#ChangeScript
<http://datashapes.org/dash#ChangeScript> rdfs:subClassOf <http://datashapes.org/dash#Script> .


###  http://datashapes.org/dash#CommitScript
<http://datashapes.org/dash#CommitScript> rdfs:subClassOf <http://datashapes.org/dash#Script> .


###  http://datashapes.org/dash#Constructor
<http://datashapes.org/dash#Constructor> rdfs:subClassOf <http://datashapes.org/dash#Script> ,
                                                         <http://www.w3.org/ns/shacl#Parameterizable> .


###  http://datashapes.org/dash#Editor
<http://datashapes.org/dash#Editor> rdfs:subClassOf <http://datashapes.org/dash#Widget> .


###  http://datashapes.org/dash#ExploreAction
<http://datashapes.org/dash#ExploreAction> rdfs:subClassOf <http://datashapes.org/dash#ResourceAction> .


###  http://datashapes.org/dash#FailureResult
<http://datashapes.org/dash#FailureResult> rdf:type owl:Class ;
                                           rdfs:subClassOf <http://www.w3.org/ns/shacl#AbstractResult> ;
