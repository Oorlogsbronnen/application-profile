@prefix : <https://data.oorlogsbronnen.nl/oorlogsbronnen-shapes#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://data.oorlogsbronnen.nl/oorlogsbronnen-shapes#> .

<https://data.oorlogsbronnen.nl/oorlogsbronnen-shapes> rdf:type owl:Ontology ;
                                                        owl:imports <http://datashapes.org/dash> ;
                                                        rdfs:label "Oorlogsbronnen SHACL Shapes"@nl .

#################################################################
#    Annotation properties
#################################################################

###  http://data.oorlogsbronnen.nl/model#imageIIIF
<http://data.oorlogsbronnen.nl/model#imageIIIF> rdf:comment "IIIF manifest van afbeeldingen die bij de bron beschikbaar zijn in IIIF formaat"@nl ;
                                                rdfs:label "IIIF Manifest"@nl ;
                                                rdf:type owl:AnnotationProperty ;
                                                rdfs:subPropertyOf <http://schema.org/image> .


###  http://schema.org/actor
<http://schema.org/actor> rdf:type owl:AnnotationProperty .


###  http://schema.org/image
<http://schema.org/image> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/1999/02/22-rdf-syntax-ns#comment
rdf:comment rdf:type owl:AnnotationProperty .


###  https://data.niod.nl/genoemde
<https://data.niod.nl/genoemde> rdf:comment "Een persoon die genoemd wordt bij een bekendmaking"@nl ;
                                rdfs:label "genoemde"@nl ;
                                rdf:type owl:AnnotationProperty ;
                                rdfs:subPropertyOf <http://schema.org/actor> .


###  https://data.niod.nl/opdrachtgever
<https://data.niod.nl/opdrachtgever> rdf:comment "Een persoon die de opdrachtgever was van een bekendmaking"@nl ;
                                     rdfs:label "opdrachtgever"@nl ;
                                     rdf:type owl:AnnotationProperty ;
                                     rdfs:subPropertyOf <http://schema.org/actor> .


###  https://data.niod.nl/slachtoffer
<https://data.niod.nl/slachtoffer> rdf:comment "Een persoon die slachtoffer was in een gebeurtenis"@nl ;
                                   rdfs:label "slachtoffer"@nl ;
                                   rdf:type owl:AnnotationProperty ;
                                   rdfs:subPropertyOf <http://schema.org/actor> .


#################################################################
#    Classes
#################################################################

###  http://data.oorlogsbronnen.nl/model#Afbeelding
<http://data.oorlogsbronnen.nl/model#Afbeelding> rdf:type owl:Class ;
                                                 rdfs:subClassOf <http://schema.org/CreativeWork> ;
                                                 rdf:comment "Superclass of all collection objects with a visuel element."@en ;
                                                 rdfs:label "Afbeelding"@nl .


###  http://data.oorlogsbronnen.nl/model#Archiefmateriaal
<http://data.oorlogsbronnen.nl/model#Archiefmateriaal> rdf:type owl:Class ;
                                                       rdfs:subClassOf <http://schema.org/CreativeWork> ;
                                                       rdf:comment "Class for all archivematerial"@en ;
                                                       rdfs:label "Archiefmateriaal"@nl .


###  http://data.oorlogsbronnen.nl/model#Archive
<http://data.oorlogsbronnen.nl/model#Archive> rdf:type owl:Class ;
                                              rdfs:subClassOf <http://data.oorlogsbronnen.nl/model#Archiefmateriaal> ,
                                                              <http://schema.org/CreativeWork> ;
                                              rdf:comment "Class for an archive"@en ;
                                              rdfs:label "Archief"@nl .


###  http://data.oorlogsbronnen.nl/model#ArchiveFile
<http://data.oorlogsbronnen.nl/model#ArchiveFile> rdf:type owl:Class ;
                                                  rdfs:subClassOf <http://data.oorlogsbronnen.nl/model#Archiefmateriaal> ,
                                                                  <https://data.niod.nl/Archive> ;
                                                  rdf:comment "Class for archival documents"@en ;
                                                  rdfs:label "Archiefstuk"@nl .


###  http://data.oorlogsbronnen.nl/model#ArchiveSeries
<http://data.oorlogsbronnen.nl/model#ArchiveSeries> rdf:type owl:Class ;
                                                    rdfs:subClassOf <http://data.oorlogsbronnen.nl/model#Archiefmateriaal> ,
                                                                    <https://data.niod.nl/Archive> ;
                                                    rdf:comment "Class for a collection of archival documents"@en ;
                                                    rdfs:label "Archiefreeks"@nl .


###  http://data.oorlogsbronnen.nl/model#Bekendmaking
<http://data.oorlogsbronnen.nl/model#Bekendmaking> rdf:type owl:Class ;
                                                   rdfs:subClassOf <https://data.niod.nl/Afbeelding> .


###  http://data.oorlogsbronnen.nl/model#Certificate
<http://data.oorlogsbronnen.nl/model#Certificate> rdf:type owl:Class ;
