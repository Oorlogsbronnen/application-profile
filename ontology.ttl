###  http://datashapes.org/dash#toString
<http://datashapes.org/dash#toString> rdf:type <http://www.w3.org/ns/shacl#SPARQLFunction> ;
                                      <http://www.w3.org/ns/shacl#parameter> _:genid103 ;
                                      <http://www.w3.org/ns/shacl#prefixes> <http://datashapes.org/dash> ;
                                      <http://www.w3.org/ns/shacl#returnType> xsd:string ;
                                      <http://datashapes.org/dash#cachable> "true"^^xsd:boolean ;
                                      <http://www.w3.org/ns/shacl#select> """SELECT (xsd:string($arg) AS ?result)
WHERE {
}""" ;
                                      rdfs:comment "Returns a literal with datatype xsd:string that has the input value as its string. If the input value is an (URI) resource then its URI will be used." ;
                                      rdfs:label "to string" ;
                                      <http://www.w3.org/ns/shacl#labelTemplate> "Convert {$arg} to xsd:string" .

_:genid103 rdf:type <http://www.w3.org/ns/shacl#Parameter> ;
            <http://www.w3.org/ns/shacl#nodeKind> <http://www.w3.org/ns/shacl#IRIOrLiteral> ;
            <http://www.w3.org/ns/shacl#path> <http://datashapes.org/dash#arg> ;
            <http://www.w3.org/ns/shacl#description> "The input value." ;
            <http://www.w3.org/ns/shacl#name> "arg" .


###  http://datashapes.org/dash#uniqueValueForClass
<http://datashapes.org/dash#uniqueValueForClass> rdfs:label "unique value for class" .


###  http://datashapes.org/dash#uriTemplate
<http://datashapes.org/dash#uriTemplate> rdf:type <http://www.w3.org/ns/shacl#SPARQLFunction> ;
                                         <http://datashapes.org/dash#apiStatus> <http://datashapes.org/dash#Stable> ;
                                         <http://www.w3.org/ns/shacl#parameter> _:genid104 ,
                                                                                _:genid105 ;
                                         <http://www.w3.org/ns/shacl#prefixes> <http://datashapes.org/dash> ;
                                         <http://www.w3.org/ns/shacl#returnType> xsd:anyURI ;
                                         <http://datashapes.org/dash#cachable> "true"^^xsd:boolean ;
                                         <http://datashapes.org/dash#contextFree> "true"^^xsd:boolean ;
                                         <http://www.w3.org/ns/shacl#select> """SELECT ?result
WHERE {
    	BIND (xsd:anyURI(REPLACE(?template, \"\\\\{[a-zA-Z]+\\\\}\", $value)) AS ?result)
}""" ;
                                         rdfs:comment """Inserts a given value into a given URI template, producing a new xsd:anyURI literal.

In the future this should support RFC 6570 but for now it is limited to simple {...} patterns.""" ;
                                         rdfs:label "URI template" .

_:genid104 rdf:type <http://www.w3.org/ns/shacl#Parameter> ;
            <http://www.w3.org/ns/shacl#datatype> xsd:string ;
            <http://www.w3.org/ns/shacl#path> <http://datashapes.org/dash#template> ;
            <http://www.w3.org/ns/shacl#order> 0 ;
            <http://www.w3.org/ns/shacl#description> "The URI template, e.g. \"http://example.org/{symbol}\"." ;
            <http://www.w3.org/ns/shacl#name> "template" .

_:genid105 rdf:type <http://www.w3.org/ns/shacl#Parameter> ;
            <http://www.w3.org/ns/shacl#nodeKind> <http://www.w3.org/ns/shacl#Literal> ;
            <http://www.w3.org/ns/shacl#path> <http://datashapes.org/dash#value> ;
            <http://www.w3.org/ns/shacl#order> 1 ;
            <http://www.w3.org/ns/shacl#description> "The literal value to insert into the template. Will use the URI-encoded string of the lexical form (for now)." ;
            <http://www.w3.org/ns/shacl#name> "value" .


###  http://datashapes.org/dash#valueCount
<http://datashapes.org/dash#valueCount> rdf:type <http://www.w3.org/ns/shacl#SPARQLFunction> ;
                                        <http://datashapes.org/dash#apiStatus> <http://datashapes.org/dash#Stable> ;
                                        <http://www.w3.org/ns/shacl#parameter> _:genid106 ,
                                                                               _:genid107 ;
                                        <http://www.w3.org/ns/shacl#prefixes> <http://datashapes.org/dash> ;
                                        <http://www.w3.org/ns/shacl#returnType> xsd:integer ;
                                        <http://www.w3.org/ns/shacl#select> """
		SELECT (COUNT(?object) AS ?result)
		WHERE {
    		$subject $predicate ?object .
		}
""" ;
                                        rdfs:comment "Computes the number of objects for a given subject/predicate combination." ;
                                        rdfs:label "value count" .

_:genid106 rdf:type <http://www.w3.org/ns/shacl#Parameter> ;
            <http://www.w3.org/ns/shacl#class> rdfs:Resource ;
            <http://www.w3.org/ns/shacl#path> <http://datashapes.org/dash#subject> ;
            <http://www.w3.org/ns/shacl#order> 0 ;
            <http://www.w3.org/ns/shacl#description> "The subject to get the number of objects of." ;
            <http://www.w3.org/ns/shacl#name> "subject" .

_:genid107 rdf:type <http://www.w3.org/ns/shacl#Parameter> ;
            <http://www.w3.org/ns/shacl#class> rdfs:Resource ;
            <http://www.w3.org/ns/shacl#path> <http://datashapes.org/dash#predicate> ;
            <http://www.w3.org/ns/shacl#order> 1 ;
            <http://www.w3.org/ns/shacl#description> "The predicate to get the number of objects of." ;
            <http://www.w3.org/ns/shacl#name> "predicate" .


