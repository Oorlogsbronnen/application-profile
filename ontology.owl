    <!-- http://data.oorlogsbronnen.nl/model#imageIIIF -->


    <owl:AnnotationProperty rdf:about="http://data.oorlogsbronnen.nl/model#imageIIIF">
        <rdf:comment xml:lang="nl">IIIF manifest van afbeeldingen die bij de bron beschikbaar zijn in IIIF formaat</rdf:comment>
        <rdfs:label xml:lang="nl">IIIF Manifest</rdfs:label>
        <rdfs:subPropertyOf rdf:resource="http://schema.org/image"/>
    </owl:AnnotationProperty>
    


    <!-- http://schema.org/actor -->


    <owl:AnnotationProperty rdf:about="http://schema.org/actor"/>
    


    <!-- http://schema.org/image -->


    <owl:AnnotationProperty rdf:about="http://schema.org/image"/>
    


    <!-- http://www.w3.org/1999/02/22-rdf-syntax-ns#comment -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/1999/02/22-rdf-syntax-ns#comment"/>
    


    <!-- https://data.niod.nl/genoemde -->


    <owl:AnnotationProperty rdf:about="https://data.niod.nl/genoemde">
        <rdf:comment xml:lang="nl">Een persoon die genoemd wordt bij een bekendmaking</rdf:comment>
        <rdfs:label xml:lang="nl">genoemde</rdfs:label>
        <rdfs:subPropertyOf rdf:resource="http://schema.org/actor"/>
    </owl:AnnotationProperty>
    


    <!-- https://data.niod.nl/opdrachtgever -->


    <owl:AnnotationProperty rdf:about="https://data.niod.nl/opdrachtgever">
        <rdf:comment xml:lang="nl">Een persoon die de opdrachtgever was van een bekendmaking</rdf:comment>
        <rdfs:label xml:lang="nl">opdrachtgever</rdfs:label>
        <rdfs:subPropertyOf rdf:resource="http://schema.org/actor"/>
    </owl:AnnotationProperty>
    


    <!-- https://data.niod.nl/slachtoffer -->


    <owl:AnnotationProperty rdf:about="https://data.niod.nl/slachtoffer">
        <rdf:comment xml:lang="nl">Een persoon die slachtoffer was in een gebeurtenis</rdf:comment>
        <rdfs:label xml:lang="nl">slachtoffer</rdfs:label>
        <rdfs:subPropertyOf rdf:resource="http://schema.org/actor"/>
    </owl:AnnotationProperty>
    


