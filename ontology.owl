    <!-- http://datashapes.org/dash#AllObjectsTarget -->


    <rdf:Description rdf:about="http://datashapes.org/dash#AllObjectsTarget">
        <rdf:type rdf:resource="http://www.w3.org/ns/shacl#SPARQLTargetType"/>
        <shacl:prefixes rdf:resource="http://datashapes.org/dash"/>
        <shacl:select>SELECT DISTINCT ?this
