        <rdfs:label xml:lang="nl">Geliquideerd</rdfs:label>
    </owl:Class>
    


    <!-- https://data.niod.nl/Gepleegd -->


    <owl:Class rdf:about="https://data.niod.nl/Gepleegd">
        <rdfs:subClassOf rdf:resource="http://schema.org/Event"/>
        <rdfs:comment xml:lang="nl">Het uitvoeren van een (ondermijnende) activiteit, zoals een aanslag of overval. Werkwoord om de uitvoerder van de aanslag te benoemen.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://data.niod.nl/WO2_Thesaurus/events/6355"/>
        <rdfs:label xml:lang="nl">Gepleegd</rdfs:label>
    </owl:Class>
    


