    <!-- https://data.niod.nl/genoemde -->


    <AnnotationProperty rdf:about="https://data.niod.nl/genoemde">
        <rdf:comment xml:lang="nl">Een persoon die genoemd wordt bij een bekendmaking</rdf:comment>
        <rdfs:label xml:lang="nl">genoemde</rdfs:label>
        <rdfs:subPropertyOf rdf:resource="http://schema.org/actor"/>
    </AnnotationProperty>
    


    <!-- https://data.niod.nl/imageIIIF -->


    <AnnotationProperty rdf:about="https://data.niod.nl/imageIIIF">
        <rdf:comment xml:lang="nl">IIIF manifest van afbeeldingen die bij de bron beschikbaar zijn in IIIF formaat</rdf:comment>
        <rdfs:label xml:lang="nl">IIIF Manifest</rdfs:label>
        <rdfs:subPropertyOf rdf:resource="http://schema.org/image"/>
    </AnnotationProperty>
    


    <!-- https://data.niod.nl/opdrachtgever -->


    <AnnotationProperty rdf:about="https://data.niod.nl/opdrachtgever">
        <rdf:comment xml:lang="nl">Een persoon die de opdrachtgever was van een bekendmaking</rdf:comment>
        <rdfs:label xml:lang="nl">opdrachtgever</rdfs:label>
