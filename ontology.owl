        <rdfs:label xml:lang="nl">Afbeelding</rdfs:label>
    </Class>
    


    <!-- https://data.niod.nl/Afgepakt -->


    <Class rdf:about="https://data.niod.nl/Afgepakt">
        <rdfs:subClassOf rdf:resource="http://schema.org/Event"/>
        <rdfs:comment xml:lang="nl">Afgepakt is de term voor de persoonlijke gebeurtenis waarbij roerende of onroerende bezittingen afgenomen worden van de eigenaar.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://data.niod.nl/WO2_Thesaurus/19486"/>
        <rdfs:label xml:lang="nl">Afgepakt</rdfs:label>
    </Class>
    


    <!-- https://data.niod.nl/Archiefmateriaal -->


