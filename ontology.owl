    <owl:Class rdf:about="https://data.niod.nl/Getransporteerd">
        <rdfs:subClassOf rdf:resource="http://schema.org/Event"/>
        <rdfs:isDefinedBy rdf:resource="https://data.niod.nl/WO2_Thesaurus/events/6348"/>
        <rdfs:label xml:lang="nl">Getransporteerd</rdfs:label>
    </owl:Class>
    


    <!-- https://data.niod.nl/Getroffen -->


    <owl:Class rdf:about="https://data.niod.nl/Getroffen">
        <rdfs:subClassOf rdf:resource="http://schema.org/Event"/>
        <rdfs:isDefinedBy rdf:resource="https://data.niod.nl/WO2_Thesaurus/events/6356"/>
        <rdfs:label xml:lang="nl">Getroffen</rdfs:label>
    </owl:Class>
    


    <!-- https://data.niod.nl/Gevangen -->


    <owl:Class rdf:about="https://data.niod.nl/Gevangen">
        <rdfs:subClassOf rdf:resource="http://schema.org/Event"/>
        <rdfs:comment xml:lang="nl">Gevangen verwijst naar de gevangenschap van burgers in (concentratie)kampen en gevangenissen. Voor krijgsgevangenen gebruiken we &apos;Geïnterneerd&apos;. Ook voor gevangen burgers uit Nederlands-Indië wordt de term &apos;Geïnterneerd&apos; gebruikt.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://data.niod.nl/WO2_Thesaurus/events/6354"/>
        <rdfs:label xml:lang="nl">Gevangen</rdfs:label>
    </owl:Class>
    


    <!-- https://data.niod.nl/Gevaren -->


    <owl:Class rdf:about="https://data.niod.nl/Gevaren">
        <rdfs:subClassOf rdf:resource="http://schema.org/Event"/>
        <rdfs:isDefinedBy rdf:resource="https://data.niod.nl/WO2_Thesaurus/events/11181"/>
        <rdfs:label xml:lang="nl">Gevaren</rdfs:label>
    </owl:Class>
    


    <!-- https://data.niod.nl/Gevlucht -->


    <owl:Class rdf:about="https://data.niod.nl/Gevlucht">
        <rdfs:subClassOf rdf:resource="http://schema.org/Event"/>
        <rdfs:isDefinedBy rdf:resource="https://data.niod.nl/WO2_Thesaurus/events/6353"/>
        <rdfs:label xml:lang="nl">Gevlucht</rdfs:label>
    </owl:Class>
    


    <!-- https://data.niod.nl/Gevochten -->


    <owl:Class rdf:about="https://data.niod.nl/Gevochten">
        <rdfs:subClassOf rdf:resource="http://schema.org/Event"/>
        <rdfs:isDefinedBy rdf:resource="https://data.niod.nl/WO2_Thesaurus/events/6359"/>
        <rdfs:label xml:lang="nl">Gevochten</rdfs:label>
    </owl:Class>
    


    <!-- https://data.niod.nl/Geëvacueerd -->


    <owl:Class rdf:about="https://data.niod.nl/Geëvacueerd">
        <rdfs:subClassOf rdf:resource="http://schema.org/Event"/>
        <rdfs:isDefinedBy rdf:resource="https://data.niod.nl/WO2_Thesaurus/events/11174"/>
        <rdfs:label xml:lang="nl">Geëvacueerd</rdfs:label>
    </owl:Class>
    


    <!-- https://data.niod.nl/Geëxecuteerd -->


    <owl:Class rdf:about="https://data.niod.nl/Geëxecuteerd">
        <rdfs:subClassOf rdf:resource="http://schema.org/Event"/>
        <rdfs:comment xml:lang="nl">Standrechtelijk omgebracht worden. Geëxecuteerd is het werkwoord om het slachtoffer van de executie te benoemen.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://data.niod.nl/WO2_Thesaurus/events/6357"/>
        <rdfs:label xml:lang="nl">Geëxecuteerd</rdfs:label>
    </owl:Class>
    


    <!-- https://data.niod.nl/Geïnterneerd -->


    <owl:Class rdf:about="https://data.niod.nl/Geïnterneerd">
        <rdfs:subClassOf rdf:resource="http://schema.org/Event"/>
        <rdfs:comment xml:lang="nl">Geïnterneerd verwijst naar militairen die gevangen zitten in kampen of gevangenissen. Ook naar burgers in Nederlands-Indië die gevangen zitten in kampen wordt verwezen als geïnterneerden. Voor alle overige burgers in kampen en gevangenissen gebruiken we &apos;Gevangen&apos;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://data.niod.nl/WO2_Thesaurus/events/6349"/>
        <rdfs:label xml:lang="nl">Geïnterneerd</rdfs:label>
    </owl:Class>
    


    <!-- https://data.niod.nl/LidGeweest -->


    <owl:Class rdf:about="https://data.niod.nl/LidGeweest">
