        <rdfs:comment xml:lang="nl">Het actief arresteren of oppakken van mensen. Werkwoord om de arresterende persoon te benoemen.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://data.niod.nl/WO2_Thesaurus/events/11179"/>
        <rdfs:label xml:lang="nl">Arresteert</rdfs:label>
    </owl:Class>
    


