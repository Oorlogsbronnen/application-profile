    <!-- http://www.w3.org/1999/02/22-rdf-syntax-ns#type -->


    <owl:NamedIndividual rdf:about="http://www.w3.org/1999/02/22-rdf-syntax-ns#type"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#Concept -->


    <owl:NamedIndividual rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
    


    <!-- http://www.w3.org/ns/prov#Entity -->


    <owl:NamedIndividual rdf:about="http://www.w3.org/ns/prov#Entity"/>
    


    <!-- http://www.w3.org/ns/prov#hadPrimarySource -->


    <owl:NamedIndividual rdf:about="http://www.w3.org/ns/prov#hadPrimarySource"/>
    


    <!-- http://www.w3.org/ns/prov#wasDerivedFrom -->


    <owl:NamedIndividual rdf:about="http://www.w3.org/ns/prov#wasDerivedFrom"/>
    


    <!-- http://www.w3.org/ns/shacl#AbstractResult -->


    <rdf:Description rdf:about="http://www.w3.org/ns/shacl#AbstractResult">
        <dash:abstract rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</dash:abstract>
    </rdf:Description>
    


    <!-- http://www.w3.org/ns/shacl#ClassConstraintComponent -->


    <rdf:Description rdf:about="http://www.w3.org/ns/shacl#ClassConstraintComponent">
        <shacl:validator rdf:resource="http://datashapes.org/dash#hasClass"/>
        <shacl:labelTemplate>Value needs to have class {$class}</shacl:labelTemplate>
    </rdf:Description>
    


    <!-- http://www.w3.org/ns/shacl#ClosedConstraintComponent -->


    <rdf:Description rdf:about="http://www.w3.org/ns/shacl#ClosedConstraintComponent">
        <shacl:nodeValidator rdf:nodeID="genid108"/>
        <dash:localConstraint rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</dash:localConstraint>
        <shacl:labelTemplate>Closed shape: only the enumerated properties can be used</shacl:labelTemplate>
    </rdf:Description>
    <rdf:Description rdf:nodeID="genid108">
        <rdf:type rdf:resource="http://www.w3.org/ns/shacl#SPARQLSelectValidator"/>
        <shacl:prefixes rdf:resource="http://datashapes.org/dash"/>
        <shacl:select>
		SELECT $this (?predicate AS ?path) ?value
		WHERE {
			{
				FILTER ($closed) .
			}
			$this ?predicate ?value .
			FILTER (NOT EXISTS {
				GRAPH $shapesGraph {
					$currentShape sh:property/sh:path ?predicate .
				}
			} &amp;&amp; (!bound($ignoredProperties) || NOT EXISTS {
				GRAPH $shapesGraph {
					$ignoredProperties rdf:rest*/rdf:first ?predicate .
				}
			}))
		}
</shacl:select>
        <shacl:message>Predicate {?path} is not allowed (closed shape)</shacl:message>
    </rdf:Description>
    


    <!-- http://www.w3.org/ns/shacl#DatatypeConstraintComponent -->


    <rdf:Description rdf:about="http://www.w3.org/ns/shacl#DatatypeConstraintComponent">
        <dash:staticConstraint rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</dash:staticConstraint>
        <shacl:labelTemplate>Values must have datatype {$datatype}</shacl:labelTemplate>
        <shacl:message>Value does not have datatype {$datatype}</shacl:message>
    </rdf:Description>
    


    <!-- http://www.w3.org/ns/shacl#DisjointConstraintComponent -->


    <rdf:Description rdf:about="http://www.w3.org/ns/shacl#DisjointConstraintComponent">
        <shacl:validator rdf:nodeID="genid109"/>
        <dash:localConstraint rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</dash:localConstraint>
    </rdf:Description>
    <rdf:Description rdf:nodeID="genid109">
        <rdf:type rdf:resource="http://www.w3.org/ns/shacl#SPARQLAskValidator"/>
        <shacl:prefixes rdf:resource="http://datashapes.org/dash"/>
        <shacl:ask>
		ASK {
			FILTER NOT EXISTS {
				$this $disjoint $value .
			}
		}
		</shacl:ask>
        <shacl:message>Property must not share any values with {$disjoint}</shacl:message>
    </rdf:Description>
    


    <!-- http://www.w3.org/ns/shacl#EqualsConstraintComponent -->


    <rdf:Description rdf:about="http://www.w3.org/ns/shacl#EqualsConstraintComponent">
        <shacl:nodeValidator rdf:nodeID="genid110"/>
        <shacl:propertyValidator rdf:nodeID="genid111"/>
        <dash:localConstraint rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</dash:localConstraint>
        <shacl:message>Must have same values as {$equals}</shacl:message>
    </rdf:Description>
    <rdf:Description rdf:nodeID="genid110">
        <rdf:type rdf:resource="http://www.w3.org/ns/shacl#SPARQLSelectValidator"/>
        <shacl:prefixes rdf:resource="http://datashapes.org/dash"/>
        <shacl:select>
		SELECT DISTINCT $this ?value
		WHERE {
			{
				FILTER NOT EXISTS { $this $equals $this }
				BIND ($this AS ?value) .
			}
			UNION
			{
				$this $equals ?value .
				FILTER (?value != $this) .
			}
		}
		</shacl:select>
    </rdf:Description>
    <rdf:Description rdf:nodeID="genid111">
        <rdf:type rdf:resource="http://www.w3.org/ns/shacl#SPARQLSelectValidator"/>
        <shacl:prefixes rdf:resource="http://datashapes.org/dash"/>
        <shacl:select>
		SELECT DISTINCT $this ?value
		WHERE {
			{
				$this $PATH ?value .
				MINUS {
					$this $equals ?value .
				}
			}
			UNION
			{
				$this $equals ?value .
				MINUS {
					$this $PATH ?value .
				}
			}
		}
		</shacl:select>
    </rdf:Description>
    


    <!-- http://www.w3.org/ns/shacl#Function -->


    <rdf:Description rdf:about="http://www.w3.org/ns/shacl#Function">
        <dash:abstract rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</dash:abstract>
    </rdf:Description>
    


    <!-- http://www.w3.org/ns/shacl#HasValueConstraintComponent -->


    <rdf:Description rdf:about="http://www.w3.org/ns/shacl#HasValueConstraintComponent">
        <shacl:nodeValidator rdf:nodeID="genid112"/>
        <shacl:propertyValidator rdf:nodeID="genid113"/>
        <dash:localConstraint rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</dash:localConstraint>
        <shacl:labelTemplate>Must have value {$hasValue}</shacl:labelTemplate>
    </rdf:Description>
    <rdf:Description rdf:nodeID="genid112">
        <rdf:type rdf:resource="http://www.w3.org/ns/shacl#SPARQLAskValidator"/>
        <shacl:prefixes rdf:resource="http://datashapes.org/dash"/>
        <shacl:ask>ASK {
    FILTER ($value = $hasValue)
}</shacl:ask>
        <shacl:message>Value must be {$hasValue}</shacl:message>
    </rdf:Description>
    <rdf:Description rdf:nodeID="genid113">
        <rdf:type rdf:resource="http://www.w3.org/ns/shacl#SPARQLSelectValidator"/>
        <shacl:prefixes rdf:resource="http://datashapes.org/dash"/>
        <shacl:select>
		SELECT $this
		WHERE {
			FILTER NOT EXISTS { $this $PATH $hasValue }
		}
		</shacl:select>
        <shacl:message>Missing expected value {$hasValue}</shacl:message>
    </rdf:Description>
    


    <!-- http://www.w3.org/ns/shacl#InConstraintComponent -->


    <rdf:Description rdf:about="http://www.w3.org/ns/shacl#InConstraintComponent">
        <shacl:validator rdf:resource="http://datashapes.org/dash#isIn"/>
        <dash:localConstraint rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</dash:localConstraint>
        <shacl:labelTemplate>Value must be in {$in}</shacl:labelTemplate>
        <shacl:message>Value is not in {$in}</shacl:message>
    </rdf:Description>
    


    <!-- http://www.w3.org/ns/shacl#LanguageInConstraintComponent -->


    <rdf:Description rdf:about="http://www.w3.org/ns/shacl#LanguageInConstraintComponent">
        <shacl:validator rdf:resource="http://datashapes.org/dash#isLanguageIn"/>
        <dash:localConstraint rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</dash:localConstraint>
        <shacl:labelTemplate>Language must match any of {$languageIn}</shacl:labelTemplate>
        <shacl:message>Language does not match any of {$languageIn}</shacl:message>
    </rdf:Description>
    


    <!-- http://www.w3.org/ns/shacl#LessThanConstraintComponent -->


    <rdf:Description rdf:about="http://www.w3.org/ns/shacl#LessThanConstraintComponent">
        <shacl:propertyValidator rdf:nodeID="genid114"/>
        <dash:localConstraint rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</dash:localConstraint>
        <shacl:message>Value is not &lt; value of {$lessThan}</shacl:message>
    </rdf:Description>
    <rdf:Description rdf:nodeID="genid114">
        <rdf:type rdf:resource="http://www.w3.org/ns/shacl#SPARQLSelectValidator"/>
        <shacl:prefixes rdf:resource="http://datashapes.org/dash"/>
        <shacl:select>
		SELECT $this ?value
		WHERE {
			$this $PATH ?value .
			$this $lessThan ?otherValue .
			BIND (?value &lt; ?otherValue AS ?result) .
			FILTER (!bound(?result) || !(?result)) .
		}
		</shacl:select>
    </rdf:Description>
    


    <!-- http://www.w3.org/ns/shacl#LessThanOrEqualsConstraintComponent -->


    <rdf:Description rdf:about="http://www.w3.org/ns/shacl#LessThanOrEqualsConstraintComponent">
        <shacl:propertyValidator rdf:nodeID="genid115"/>
        <dash:localConstraint rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</dash:localConstraint>
        <shacl:message>Value is not &lt;= value of {$lessThanOrEquals}</shacl:message>
    </rdf:Description>
    <rdf:Description rdf:nodeID="genid115">
        <rdf:type rdf:resource="http://www.w3.org/ns/shacl#SPARQLSelectValidator"/>
        <shacl:prefixes rdf:resource="http://datashapes.org/dash"/>
        <shacl:select>
		SELECT DISTINCT $this ?value
		WHERE {
			$this $PATH ?value .
			$this $lessThanOrEquals ?otherValue .
			BIND (?value &lt;= ?otherValue AS ?result) .
			FILTER (!bound(?result) || !(?result)) .
		}
</shacl:select>
    </rdf:Description>
    


    <!-- http://www.w3.org/ns/shacl#MaxCountConstraintComponent -->


    <rdf:Description rdf:about="http://www.w3.org/ns/shacl#MaxCountConstraintComponent">
        <shacl:propertyValidator rdf:nodeID="genid116"/>
        <dash:localConstraint rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</dash:localConstraint>
        <shacl:labelTemplate>Must not have more than {$maxCount} values</shacl:labelTemplate>
        <shacl:message>More than {$maxCount} values</shacl:message>
    </rdf:Description>
    <rdf:Description rdf:nodeID="genid116">
        <rdf:type rdf:resource="http://www.w3.org/ns/shacl#SPARQLSelectValidator"/>
        <shacl:prefixes rdf:resource="http://datashapes.org/dash"/>
        <shacl:select>
		SELECT $this
		WHERE {
			$this $PATH ?value .
		}
		GROUP BY $this
		HAVING (COUNT(DISTINCT ?value) &gt; $maxCount)
		</shacl:select>
    </rdf:Description>
    


    <!-- http://www.w3.org/ns/shacl#MaxExclusiveConstraintComponent -->


    <rdf:Description rdf:about="http://www.w3.org/ns/shacl#MaxExclusiveConstraintComponent">
        <shacl:validator rdf:resource="http://datashapes.org/dash#hasMaxExclusive"/>
        <dash:staticConstraint rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</dash:staticConstraint>
        <shacl:labelTemplate>Value must be &lt; {$maxExclusive}</shacl:labelTemplate>
        <shacl:message>Value is not &lt; {$maxExclusive}</shacl:message>
    </rdf:Description>
    


    <!-- http://www.w3.org/ns/shacl#MaxInclusiveConstraintComponent -->


    <rdf:Description rdf:about="http://www.w3.org/ns/shacl#MaxInclusiveConstraintComponent">
        <shacl:validator rdf:resource="http://datashapes.org/dash#hasMaxInclusive"/>
        <dash:staticConstraint rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</dash:staticConstraint>
        <shacl:labelTemplate>Value must be &lt;= {$maxInclusive}</shacl:labelTemplate>
        <shacl:message>Value is not &lt;= {$maxInclusive}</shacl:message>
    </rdf:Description>
    


    <!-- http://www.w3.org/ns/shacl#MaxLengthConstraintComponent -->


    <rdf:Description rdf:about="http://www.w3.org/ns/shacl#MaxLengthConstraintComponent">
        <shacl:validator rdf:resource="http://datashapes.org/dash#hasMaxLength"/>
        <dash:staticConstraint rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</dash:staticConstraint>
        <shacl:labelTemplate>Value must not have more than {$maxLength} characters</shacl:labelTemplate>
        <shacl:message>Value has more than {$maxLength} characters</shacl:message>
    </rdf:Description>
    


    <!-- http://www.w3.org/ns/shacl#MinCountConstraintComponent -->


    <rdf:Description rdf:about="http://www.w3.org/ns/shacl#MinCountConstraintComponent">
        <shacl:propertyValidator rdf:nodeID="genid117"/>
        <dash:localConstraint rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</dash:localConstraint>
        <shacl:labelTemplate>Must have at least {$minCount} values</shacl:labelTemplate>
        <shacl:message>Fewer than {$minCount} values</shacl:message>
    </rdf:Description>
    <rdf:Description rdf:nodeID="genid117">
        <rdf:type rdf:resource="http://www.w3.org/ns/shacl#SPARQLSelectValidator"/>
        <shacl:prefixes rdf:resource="http://datashapes.org/dash"/>
        <shacl:select>
		SELECT $this
		WHERE {
			OPTIONAL {
				$this $PATH ?value .
			}
		}
		GROUP BY $this
		HAVING (COUNT(DISTINCT ?value) &lt; $minCount)
		</shacl:select>
    </rdf:Description>
    


    <!-- http://www.w3.org/ns/shacl#MinExclusiveConstraintComponent -->


    <rdf:Description rdf:about="http://www.w3.org/ns/shacl#MinExclusiveConstraintComponent">
        <shacl:validator rdf:resource="http://datashapes.org/dash#hasMinExclusive"/>
        <dash:staticConstraint rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</dash:staticConstraint>
        <shacl:labelTemplate>Value must be &gt; {$minExclusive}</shacl:labelTemplate>
        <shacl:message>Value is not &gt; {$minExclusive}</shacl:message>
    </rdf:Description>
    


    <!-- http://www.w3.org/ns/shacl#MinInclusiveConstraintComponent -->


    <rdf:Description rdf:about="http://www.w3.org/ns/shacl#MinInclusiveConstraintComponent">
        <shacl:validator rdf:resource="http://datashapes.org/dash#hasMinInclusive"/>
        <dash:staticConstraint rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</dash:staticConstraint>
        <shacl:labelTemplate>Value must be &gt;= {$minInclusive}</shacl:labelTemplate>
        <shacl:message>Value is not &gt;= {$minInclusive}</shacl:message>
    </rdf:Description>
    


    <!-- http://www.w3.org/ns/shacl#MinLengthConstraintComponent -->


    <rdf:Description rdf:about="http://www.w3.org/ns/shacl#MinLengthConstraintComponent">
        <shacl:validator rdf:resource="http://datashapes.org/dash#hasMinLength"/>
        <dash:staticConstraint rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</dash:staticConstraint>
        <shacl:labelTemplate>Value must have less than {$minLength} characters</shacl:labelTemplate>
        <shacl:message>Value has less than {$minLength} characters</shacl:message>
    </rdf:Description>
    


    <!-- http://www.w3.org/ns/shacl#NodeKindConstraintComponent -->


    <rdf:Description rdf:about="http://www.w3.org/ns/shacl#NodeKindConstraintComponent">
        <shacl:validator rdf:resource="http://datashapes.org/dash#hasNodeKind"/>
        <dash:staticConstraint rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</dash:staticConstraint>
        <shacl:labelTemplate>Value must have node kind {$nodeKind}</shacl:labelTemplate>
        <shacl:message>Value does not have node kind {$nodeKind}</shacl:message>
    </rdf:Description>
    


    <!-- http://www.w3.org/ns/shacl#Parameterizable -->


    <rdf:Description rdf:about="http://www.w3.org/ns/shacl#Parameterizable">
        <dash:abstract rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</dash:abstract>
    </rdf:Description>
    


    <!-- http://www.w3.org/ns/shacl#PatternConstraintComponent -->


    <rdf:Description rdf:about="http://www.w3.org/ns/shacl#PatternConstraintComponent">
        <shacl:validator rdf:resource="http://datashapes.org/dash#hasPattern"/>
        <dash:staticConstraint rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</dash:staticConstraint>
        <shacl:labelTemplate>Value must match pattern &quot;{$pattern}&quot;</shacl:labelTemplate>
        <shacl:message>Value does not match pattern &quot;{$pattern}&quot;</shacl:message>
    </rdf:Description>
    


    <!-- http://www.w3.org/ns/shacl#Rule -->


    <rdf:Description rdf:about="http://www.w3.org/ns/shacl#Rule">
        <dash:abstract rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</dash:abstract>
    </rdf:Description>
    


    <!-- http://www.w3.org/ns/shacl#Rules -->


    <rdf:Description rdf:about="http://www.w3.org/ns/shacl#Rules">
        <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Resource"/>
        <rdfs:comment>The SHACL rules entailment regime.</rdfs:comment>
        <rdfs:label>SHACL Rules</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://www.w3.org/TR/shacl-af/#Rules"/>
    </rdf:Description>
    


    <!-- http://www.w3.org/ns/shacl#SPARQLExecutable -->


    <rdf:Description rdf:about="http://www.w3.org/ns/shacl#SPARQLExecutable">
        <dash:abstract rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</dash:abstract>
    </rdf:Description>
    


    <!-- http://www.w3.org/ns/shacl#Shape -->


    <rdf:Description rdf:about="http://www.w3.org/ns/shacl#Shape">
        <dash:abstract rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</dash:abstract>
    </rdf:Description>
    


    <!-- http://www.w3.org/ns/shacl#Target -->


    <rdf:Description rdf:about="http://www.w3.org/ns/shacl#Target">
        <dash:abstract rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</dash:abstract>
    </rdf:Description>
    


    <!-- http://www.w3.org/ns/shacl#TargetType -->


    <rdf:Description rdf:about="http://www.w3.org/ns/shacl#TargetType">
        <dash:abstract rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</dash:abstract>
    </rdf:Description>
    


    <!-- http://www.w3.org/ns/shacl#UniqueLangConstraintComponent -->


    <rdf:Description rdf:about="http://www.w3.org/ns/shacl#UniqueLangConstraintComponent">
        <shacl:propertyValidator rdf:nodeID="genid118"/>
        <dash:localConstraint rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</dash:localConstraint>
        <shacl:labelTemplate>No language can be used more than once</shacl:labelTemplate>
        <shacl:message>Language &quot;{?lang}&quot; used more than once</shacl:message>
    </rdf:Description>
    <rdf:Description rdf:nodeID="genid118">
        <rdf:type rdf:resource="http://www.w3.org/ns/shacl#SPARQLSelectValidator"/>
        <shacl:prefixes rdf:resource="http://datashapes.org/dash"/>
        <shacl:select>
		SELECT DISTINCT $this ?lang
		WHERE {
			{
				FILTER sameTerm($uniqueLang, true) .
			}
			$this $PATH ?value .
			BIND (lang(?value) AS ?lang) .
			FILTER (bound(?lang) &amp;&amp; ?lang != &quot;&quot;) .
			FILTER EXISTS {
				$this $PATH ?otherValue .
				FILTER (?otherValue != ?value &amp;&amp; ?lang = lang(?otherValue)) .
			}
		}
		</shacl:select>
    </rdf:Description>
    


    <!-- http://www.w3.org/ns/shacl#Validator -->


    <rdf:Description rdf:about="http://www.w3.org/ns/shacl#Validator">
        <dash:abstract rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</dash:abstract>
    </rdf:Description>
    


    <!-- https://personsincontext.org/model/#PersonObservation -->


    <owl:NamedIndividual rdf:about="https://personsincontext.org/model/#PersonObservation"/>
    


    <!-- https://personsincontext.org/model/#PersonReconstruction -->


    <owl:NamedIndividual rdf:about="https://personsincontext.org/model/#PersonReconstruction"/>
    


    <!-- https://personsincontext.org/model/#deceased -->


    <owl:NamedIndividual rdf:about="https://personsincontext.org/model/#deceased"/>
    


    <!-- https://w3id.org/pnv#initials -->


    <owl:NamedIndividual rdf:about="https://w3id.org/pnv#initials"/>
    <rdf:Description>
        <shacl:datatype rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </rdf:Description>
    <rdf:Description>
