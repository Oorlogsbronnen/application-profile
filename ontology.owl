        <rdfs:subClassOf rdf:resource="http://schema.org/CreativeWork"/>
        <rdf:comment xml:lang="en">Class for all archivematerial</rdf:comment>
        <rdfs:label xml:lang="nl">Archiefmateriaal</rdfs:label>
    </Class>
    


