        <rdfs:label xml:lang="nl">Geland</rdfs:label>
    </Class>
    


    <!-- https://data.niod.nl/Geleid -->


    <Class rdf:about="https://data.niod.nl/Geleid">
        <rdfs:subClassOf rdf:resource="http://schema.org/Event"/>
        <rdfs:comment xml:lang="nl">Leider zijn van, baas zijn over. Werkwoord om het leiden van een partij, groep of organisatie te beschrijven.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://data.niod.nl/WO2_Thesaurus/events/11182"/>
        <rdfs:label xml:lang="nl">Geleid</rdfs:label>
    </Class>
    


    <!-- https://data.niod.nl/Geliquideerd -->


    <Class rdf:about="https://data.niod.nl/Geliquideerd">
