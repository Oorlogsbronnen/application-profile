    </rdf:Description>
    <rdf:Description rdf:about="http://schema.org/Place">
        <rdfs:label xml:lang="nl">Locatie</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://schema.org/SheetMusic">
        <rdfs:label xml:lang="nl">Bladmuziek</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://schema.org/VisualArtwork">
        <rdfs:label xml:lang="nl">Kunstwerk</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.w3.org/ns/shacl#NodeConstraintComponent">
        <shacl:message>Value does not have shape {$node}</shacl:message>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.w3.org/ns/shacl#NotConstraintComponent">
        <shacl:labelTemplate>Value must not have shape {$not}</shacl:labelTemplate>
        <shacl:message>Value does have shape {$not}</shacl:message>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.w3.org/ns/shacl#QualifiedMaxCountConstraintComponent">
        <shacl:labelTemplate>No more than {$qualifiedMaxCount} values can have shape {$qualifiedValueShape}</shacl:labelTemplate>
        <shacl:message>More than {$qualifiedMaxCount} values have shape {$qualifiedValueShape}</shacl:message>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.w3.org/ns/shacl#QualifiedMinCountConstraintComponent">
        <shacl:labelTemplate>No fewer than {$qualifiedMinCount} values can have shape {$qualifiedValueShape}</shacl:labelTemplate>
